//@version=6
// Four Pillars Strategy v2.0 - BACKTESTING VERSION
// Converts the indicator logic to strategy() for backtesting
//
// METHODOLOGY:
// - Pillar 1: Ripster EMA Clouds (Structure/Trend)
// - Pillar 2: AVWAP (Directional Bias)
// - Pillar 3: Quad Rotation Stochastic (Momentum Trigger)
// - Pillar 4: BBWP (Volatility Filter)

strategy("Four Pillars v2 Strategy", shorttitle="4P Strategy", overlay=true,
         initial_capital=10000, default_qty_type=strategy.percent_of_equity,
         default_qty_value=100, commission_type=strategy.commission.percent,
         commission_value=0.075, slippage=1, pyramiding=0,
         process_orders_on_close=true)

// ═══════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════

// Pillar 1: Ripster
grp1 = "═══ PILLAR 1: STRUCTURE (Ripster) ═══"
i_ema5 = input.int(5, "Short EMA (5)", group=grp1)
i_ema12 = input.int(12, "Long EMA (12)", group=grp1)
i_ema34 = input.int(34, "Short EMA (34)", group=grp1)
i_ema50 = input.int(50, "Long EMA (50)", group=grp1)

// Pillar 2: AVWAP
grp2 = "═══ PILLAR 2: BIAS (AVWAP) ═══"
i_pivotLen = input.int(5, "Pivot Lookback", group=grp2)
i_volMaPeriod = input.int(20, "Volume MA Period", group=grp2)

// Pillar 3: Momentum (QRS)
grp3 = "═══ PILLAR 3: MOMENTUM (Stochastic) ═══"
i_oversold = input.int(20, "Oversold Level", group=grp3)
i_overbought = input.int(80, "Overbought Level", group=grp3)

// Pillar 4: BBWP
grp4 = "═══ PILLAR 4: VOLATILITY (BBWP) ═══"
i_bbLen = input.int(13, "BB Basis Length", group=grp4)
i_bbwpLookback = input.int(100, "BBWP Lookback", group=grp4)
i_bbwpExLow = input.int(10, "Extreme Low", group=grp4)
i_bbwpExHigh = input.int(90, "Extreme High", group=grp4)

// Position Management
grp5 = "═══ POSITION MANAGEMENT ═══"
i_atrLen = input.int(14, "ATR Length", group=grp5)
i_slMult = input.float(2.0, "Stop Loss ATR Mult", group=grp5, step=0.1)
i_trailMult = input.float(2.0, "Trail ATR Mult", group=grp5, step=0.1)
i_useTrailing = input.bool(true, "Use Trailing Stop", group=grp5)
i_useBE = input.bool(true, "Use Breakeven (9-3 zone)", group=grp5)

// Grade Thresholds
grp6 = "═══ GRADE THRESHOLDS ═══"
i_gradeA = input.int(9, "Grade A Minimum", group=grp6)
i_gradeB = input.int(6, "Grade B Minimum", group=grp6)
i_gradeC = input.int(4, "Grade C Minimum", group=grp6)
i_targetA = input.float(6.0, "Grade A Target (ATR)", group=grp6)
i_targetB = input.float(4.0, "Grade B Target (ATR)", group=grp6)
i_targetC = input.float(2.5, "Grade C Target (ATR)", group=grp6)
i_minGrade = input.string("C", "Minimum Grade to Trade", options=["A", "B", "C"], group=grp6)

// Trade Filters
grp9 = "═══ TRADE FILTERS ═══"
i_tradeLongs = input.bool(true, "Trade Longs", group=grp9)
i_tradeShorts = input.bool(true, "Trade Shorts", group=grp9)
i_requireBBWPBlue = input.bool(false, "Require BBWP Blue for Entry", group=grp9)
i_requireDivergence = input.bool(false, "Require Divergence (Supersignal)", group=grp9)

// ═══════════════════════════════════════════════════════════════════════════
// PILLAR 1: RIPSTER EMA CLOUDS
// ═══════════════════════════════════════════════════════════════════════════

float ema5 = ta.ema(close, i_ema5)
float ema12 = ta.ema(close, i_ema12)
float ema34 = ta.ema(close, i_ema34)
float ema50 = ta.ema(close, i_ema50)

// Cloud states
bool cloud_5_12_bull = ema5 > ema12
bool cloud_34_50_bull = ema34 > ema50

// Price position vs 34/50 cloud
float cloud_top = math.max(ema34, ema50)
float cloud_bottom = math.min(ema34, ema50)
int price_vs_cloud = close > cloud_top ? 1 : close < cloud_bottom ? -1 : 0

// Cloud direction
bool cloud_rising = ema34 > ema34[1] and ema50 > ema50[1]
bool cloud_falling = ema34 < ema34[1] and ema50 < ema50[1]

// Pillar 1 Points (0-3)
float p1_long_pts = 0.0
p1_long_pts += price_vs_cloud == 1 ? 1 : 0
p1_long_pts += cloud_34_50_bull ? 1 : 0
p1_long_pts += cloud_5_12_bull ? 1 : 0

float p1_short_pts = 0.0
p1_short_pts += price_vs_cloud == -1 ? 1 : 0
p1_short_pts += not cloud_34_50_bull ? 1 : 0
p1_short_pts += not cloud_5_12_bull ? 1 : 0

// ═══════════════════════════════════════════════════════════════════════════
// PILLAR 2: AVWAP (Simplified)
// ═══════════════════════════════════════════════════════════════════════════

float pivotHigh = ta.pivothigh(high, i_pivotLen, i_pivotLen)
float pivotLow = ta.pivotlow(low, i_pivotLen, i_pivotLen)

var float lastSwingHigh = na
var float lastSwingLow = na
var int lastSwingHighBar = na
var int lastSwingLowBar = na

if not na(pivotHigh)
    lastSwingHigh := pivotHigh
    lastSwingHighBar := bar_index - i_pivotLen

if not na(pivotLow)
    lastSwingLow := pivotLow
    lastSwingLowBar := bar_index - i_pivotLen

// Cumulative VWAP from swing low
var float cumPV_low = 0.0
var float cumV_low = 0.0

if not na(pivotLow)
    cumPV_low := 0.0
    cumV_low := 0.0
    for i = 1 to i_pivotLen
        cumPV_low += hlc3[i] * volume[i]
        cumV_low += volume[i]

if not na(lastSwingLowBar) and bar_index - lastSwingLowBar < 200
    cumPV_low += hlc3 * volume
    cumV_low += volume

float vwapFromLow = cumV_low > 0 ? cumPV_low / cumV_low : na

// Volume flow
float bullVol = close > open ? volume : 0.0
float bearVol = close < open ? volume : 0.0
float bullVolMA = ta.ema(bullVol, i_volMaPeriod)
float bearVolMA = ta.ema(bearVol, i_volMaPeriod)
bool volFlowBull = bullVolMA > bearVolMA

// Pillar 2 Points (0-3)
float p2_long_pts = 0.0
p2_long_pts += not na(vwapFromLow) and close > vwapFromLow ? 1 : 0
p2_long_pts += volFlowBull ? 1 : 0
p2_long_pts += not na(lastSwingLowBar) and bar_index - lastSwingLowBar < 50 ? 1 : 0

float p2_short_pts = 0.0
p2_short_pts += not na(vwapFromLow) and close < vwapFromLow ? 1 : 0
p2_short_pts += not volFlowBull ? 1 : 0
p2_short_pts += not na(lastSwingHighBar) and bar_index - lastSwingHighBar < 50 ? 1 : 0

// ═══════════════════════════════════════════════════════════════════════════
// PILLAR 3: QUAD ROTATION STOCHASTIC
// ═══════════════════════════════════════════════════════════════════════════

// Fast stochastic function (single smooth)
stoch_fast(int k_len, int smooth_k) =>
    float lowest = ta.lowest(low, k_len)
    float highest = ta.highest(high, k_len)
    float range_val = highest - lowest
    float k_raw = range_val == 0 ? 50.0 : 100.0 * (close - lowest) / range_val
    ta.sma(k_raw, smooth_k)

// Full stochastic function (double smooth)
stoch_full(int k_len, int smooth_k) =>
    float lowest = ta.lowest(low, k_len)
    float highest = ta.highest(high, k_len)
    float range_val = highest - lowest
    float k_raw = range_val == 0 ? 50.0 : 100.0 * (close - lowest) / range_val
    float k_smooth1 = ta.sma(k_raw, smooth_k)
    ta.sma(k_smooth1, smooth_k)

// Calculate 4 stochastics (Kurisko HPS)
float stoch_9_3 = stoch_fast(9, 3)
float stoch_14_3 = stoch_fast(14, 3)
float stoch_40_4 = stoch_fast(40, 3)   // Kurisko: K=40, Smooth=3
float stoch_60_10 = stoch_full(60, 10)

// Alignment counting
int bull_count = 0
bull_count += stoch_9_3 > 50 ? 1 : 0
bull_count += stoch_14_3 > 50 ? 1 : 0
bull_count += stoch_40_4 > 50 ? 1 : 0
bull_count += stoch_60_10 > 50 ? 1 : 0

int bear_count = 4 - bull_count

// Zone detection
bool in_oversold = stoch_40_4 < i_oversold
bool in_overbought = stoch_40_4 > i_overbought

// Turn detection (lookback + current momentum)
bool stoch_40_turning_up = stoch_40_4 > nz(stoch_40_4[3], 50) and stoch_40_4 > stoch_40_4[1]
bool stoch_40_turning_down = stoch_40_4 < nz(stoch_40_4[3], 50) and stoch_40_4 < stoch_40_4[1]

// ═══════════════════════════════════════════════════════════════════════════
// 40-4 DIVERGENCE STATE MACHINE
// ═══════════════════════════════════════════════════════════════════════════

// Bull divergence detection
var int bull_div_state = 0
var float bull_div_price = na
var float bull_div_stoch = na
var int bull_div_bar = na
bool bullish_divergence = false

if bull_div_state == 0 and stoch_40_4 < i_oversold
    bull_div_state := 1
    bull_div_price := low
    bull_div_stoch := stoch_40_4
    bull_div_bar := bar_index
else if bull_div_state == 1 and stoch_40_4 < i_oversold
    if low < bull_div_price
        bull_div_price := low
        bull_div_stoch := stoch_40_4
else if bull_div_state == 1 and stoch_40_4 >= i_oversold
    bull_div_state := 2
else if bull_div_state == 2
    if stoch_40_4 < i_oversold
        bull_div_state := 1
        bull_div_price := low
        bull_div_stoch := stoch_40_4
        bull_div_bar := bar_index
    else if bar_index - bull_div_bar > 20
        bull_div_state := 0
    else
        bool price_lower = low <= bull_div_price * 1.001
        bool stoch_higher = stoch_40_4 > bull_div_stoch
        if price_lower and stoch_higher and stoch_40_turning_up
            bullish_divergence := true
            bull_div_state := 0

// Bear divergence detection
var int bear_div_state = 0
var float bear_div_price = na
var float bear_div_stoch = na
var int bear_div_bar = na
bool bearish_divergence = false

if bear_div_state == 0 and stoch_40_4 > i_overbought
    bear_div_state := 1
    bear_div_price := high
    bear_div_stoch := stoch_40_4
    bear_div_bar := bar_index
else if bear_div_state == 1 and stoch_40_4 > i_overbought
    if high > bear_div_price
        bear_div_price := high
        bear_div_stoch := stoch_40_4
else if bear_div_state == 1 and stoch_40_4 <= i_overbought
    bear_div_state := 2
else if bear_div_state == 2
    if stoch_40_4 > i_overbought
        bear_div_state := 1
        bear_div_price := high
        bear_div_stoch := stoch_40_4
        bear_div_bar := bar_index
    else if bar_index - bear_div_bar > 20
        bear_div_state := 0
    else
        bool price_higher = high >= bear_div_price * 0.999
        bool stoch_lower = stoch_40_4 < bear_div_stoch
        if price_higher and stoch_lower and stoch_40_turning_down
            bearish_divergence := true
            bear_div_state := 0

// Pillar 3 Points (0-4)
float p3_long_pts = 0.0
p3_long_pts += bullish_divergence ? 3 : 0
p3_long_pts += bull_count >= 3 ? 1 : 0
p3_long_pts += stoch_40_turning_up and stoch_40_4 < 50 ? 1 : 0

float p3_short_pts = 0.0
p3_short_pts += bearish_divergence ? 3 : 0
p3_short_pts += bear_count >= 3 ? 1 : 0
p3_short_pts += stoch_40_turning_down and stoch_40_4 > 50 ? 1 : 0

p3_long_pts := math.min(p3_long_pts, 4)
p3_short_pts := math.min(p3_short_pts, 4)

// ═══════════════════════════════════════════════════════════════════════════
// PILLAR 4: BBWP
// ═══════════════════════════════════════════════════════════════════════════

[bbMiddle, bbUpper, bbLower] = ta.bb(close, i_bbLen, 2.0)
float bbw = bbMiddle > 0 ? (bbUpper - bbLower) / bbMiddle * 100 : 0
float bbwp = ta.percentrank(bbw, i_bbwpLookback)

bool bluBar = bbwp <= i_bbwpExLow
bool redBar = bbwp >= i_bbwpExHigh
bool bluSpectrum = bbwp < 25
bool redSpectrum = bbwp > 75

// Pillar 4 Points (0-2)
float p4_pts = 0.0
p4_pts := bluBar ? 2 : bluSpectrum ? 1 : redSpectrum or redBar ? 1 : 0

// ═══════════════════════════════════════════════════════════════════════════
// TOTAL SCORE & GRADE
// ═══════════════════════════════════════════════════════════════════════════

float total_long_pts = p1_long_pts + p2_long_pts + p3_long_pts + p4_pts
float total_short_pts = p1_short_pts + p2_short_pts + p3_short_pts + p4_pts

// ─────────────────────────────────────────────────────────────────────────────
// MOMENTUM TRIGGER: QUAD ROTATION
// 9-3 is the TRIGGER (fastest) - it crosses 25/75 first
// The REST (14-3, 40-4, 60-10) must ALL be in zone (<30 or >70)
// After entry, they must FOLLOW (move in same direction) within 3-5 bars
// ─────────────────────────────────────────────────────────────────────────────

// 9-3 crossing the zone boundary (THE TRIGGER)
bool cross_9_3_up_25 = ta.crossover(stoch_9_3, 25.0)    // 9-3 exiting oversold
bool cross_9_3_down_75 = ta.crossunder(stoch_9_3, 75.0) // 9-3 exiting overbought

// ALL must be in zone together (strict thresholds)
bool all_oversold = stoch_14_3 < 30 and stoch_40_4 < 30 and stoch_60_10 < 30
bool all_overbought = stoch_14_3 > 70 and stoch_40_4 > 70 and stoch_60_10 > 70

// Ripster structure filter
bool ripster_bullish = cloud_34_50_bull or price_vs_cloud >= 0  // Bull cloud or price not below
bool ripster_bearish = not cloud_34_50_bull or price_vs_cloud <= 0  // Bear cloud or price not above

// LONG: 9-3 crosses up through 25, all others under 30, ripster bullish
bool has_long_trigger = cross_9_3_up_25 and all_oversold and ripster_bullish

// SHORT: 9-3 crosses down through 75, all others above 70, ripster bearish
bool has_short_trigger = cross_9_3_down_75 and all_overbought and ripster_bearish

// Track if stochastics are following (for position management)
bool stochs_following_up = stoch_14_3 > stoch_14_3[1] and stoch_40_4 > stoch_40_4[1]
bool stochs_following_down = stoch_14_3 < stoch_14_3[1] and stoch_40_4 < stoch_40_4[1]

// Divergence is a SUPERSIGNAL (highest priority)
bool long_supersignal = bullish_divergence
bool short_supersignal = bearish_divergence

// Grade calculation
string grade = "—"
string direction = "FLAT"
float target_atr = 0.0

// LONG: Momentum trigger OR supersignal
if has_long_trigger or long_supersignal
    direction := "LONG"
    if total_long_pts >= i_gradeA
        grade := "A"
        target_atr := i_targetA
    else if total_long_pts >= i_gradeB
        grade := "B"
        target_atr := i_targetB
    else if total_long_pts >= i_gradeC
        grade := "C"
        target_atr := i_targetC
    else
        // Still allow entry with minimum grade C target
        grade := "C"
        target_atr := i_targetC

// SHORT: Momentum trigger OR supersignal
else if has_short_trigger or short_supersignal
    direction := "SHORT"
    if total_short_pts >= i_gradeA
        grade := "A"
        target_atr := i_targetA
    else if total_short_pts >= i_gradeB
        grade := "B"
        target_atr := i_targetB
    else if total_short_pts >= i_gradeC
        grade := "C"
        target_atr := i_targetC
    else
        // Still allow entry with minimum grade C target
        grade := "C"
        target_atr := i_targetC

// ═══════════════════════════════════════════════════════════════════════════
// TRADE FILTERS
// ═══════════════════════════════════════════════════════════════════════════

// Minimum grade filter
bool gradeOK = switch i_minGrade
    "A" => grade == "A"
    "B" => grade == "A" or grade == "B"
    "C" => grade == "A" or grade == "B" or grade == "C"
    => false

// BBWP blue filter
bool bbwpOK = i_requireBBWPBlue ? bluSpectrum : true

// Divergence filter
bool divOK = i_requireDivergence ? (bullish_divergence or bearish_divergence) : true

// Combined filter
bool filtersPass = gradeOK and bbwpOK and divOK

// ═══════════════════════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ═══════════════════════════════════════════════════════════════════════════

float atr = ta.atr(i_atrLen)

// Entry conditions
bool longEntry = direction == "LONG" and grade != "—" and filtersPass and i_tradeLongs and strategy.position_size == 0
bool shortEntry = direction == "SHORT" and grade != "—" and filtersPass and i_tradeShorts and strategy.position_size == 0

// Track position state for breakeven/trailing
var float entryPrice = na
var float initialStop = na
var float currentStop = na
var float targetPrice = na
var bool beActivated = false
var bool trailActivated = false
var int entryBar = na

// Rotation failed exit: stochastics didn't follow within 3-5 bars
if strategy.position_size > 0 and not na(entryBar)
    int barsSinceEntry = bar_index - entryBar
    if barsSinceEntry >= 3 and barsSinceEntry <= 5 and not stochs_following_up
        strategy.close("Long", comment="Rotation Failed")

if strategy.position_size < 0 and not na(entryBar)
    int barsSinceEntry = bar_index - entryBar
    if barsSinceEntry >= 3 and barsSinceEntry <= 5 and not stochs_following_down
        strategy.close("Short", comment="Rotation Failed")

// Long Entry (mutually exclusive with short)
if longEntry
    entryPrice := close
    entryBar := bar_index
    initialStop := close - (i_slMult * atr)
    currentStop := initialStop
    targetPrice := close + (target_atr * atr)
    beActivated := false
    trailActivated := false

    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=initialStop, limit=targetPrice)

// Short Entry (only if no long entry on same bar)
else if shortEntry
    entryPrice := close
    entryBar := bar_index
    initialStop := close + (i_slMult * atr)
    currentStop := initialStop
    targetPrice := close - (target_atr * atr)
    beActivated := false
    trailActivated := false

    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=initialStop, limit=targetPrice)

// Breakeven Logic (9-3 reaches opposite zone)
if strategy.position_size > 0 and i_useBE and not beActivated
    if stoch_9_3 > i_overbought
        currentStop := entryPrice
        beActivated := true
        strategy.exit("Long Exit", "Long", stop=currentStop, limit=targetPrice)

if strategy.position_size < 0 and i_useBE and not beActivated
    if stoch_9_3 < i_oversold
        currentStop := entryPrice
        beActivated := true
        strategy.exit("Short Exit", "Short", stop=currentStop, limit=targetPrice)

// Trailing Stop Logic (+2 ATR profit activates trail)
if strategy.position_size > 0 and i_useTrailing
    float profitATR = (close - entryPrice) / atr
    if profitATR >= 2
        trailActivated := true
    if trailActivated
        float trailStop = close - (i_trailMult * atr)
        if trailStop > currentStop
            currentStop := trailStop
            strategy.exit("Long Exit", "Long", stop=currentStop, limit=targetPrice)

if strategy.position_size < 0 and i_useTrailing
    float profitATR = (entryPrice - close) / atr
    if profitATR >= 2
        trailActivated := true
    if trailActivated
        float trailStop = close + (i_trailMult * atr)
        if trailStop < currentStop
            currentStop := trailStop
            strategy.exit("Short Exit", "Short", stop=currentStop, limit=targetPrice)

// Reset on position close
if strategy.position_size == 0 and strategy.position_size[1] != 0
    entryPrice := na
    entryBar := na
    initialStop := na
    currentStop := na
    targetPrice := na
    beActivated := false
    trailActivated := false

// ═══════════════════════════════════════════════════════════════════════════
// VISUALS
// ═══════════════════════════════════════════════════════════════════════════

// Entry markers
plotshape(longEntry, "Long Entry", shape.triangleup, location.belowbar, color=color.lime, size=size.normal)
plotshape(shortEntry, "Short Entry", shape.triangledown, location.abovebar, color=color.red, size=size.normal)

// EMA Clouds (optional visual)
p_ema34 = plot(ema34, "EMA 34", color=color.new(color.blue, 80))
p_ema50 = plot(ema50, "EMA 50", color=color.new(color.blue, 80))
fill(p_ema34, p_ema50, color=cloud_34_50_bull ? color.new(color.green, 90) : color.new(color.red, 90))

// Position lines
plot(strategy.position_size != 0 ? currentStop : na, "Current Stop", color=color.red, linewidth=2, style=plot.style_linebr)
plot(strategy.position_size != 0 ? targetPrice : na, "Target", color=color.green, linewidth=1, style=plot.style_linebr)

// ═══════════════════════════════════════════════════════════════════════════
// INFO TABLE
// ═══════════════════════════════════════════════════════════════════════════

var table infoTable = table.new(position.top_right, 2, 8, bgcolor=color.new(#1e222d, 10), border_width=1)

if barstate.islast
    float pts = direction == "LONG" ? total_long_pts : direction == "SHORT" ? total_short_pts : 0
    color gradeColor = grade == "A" ? color.lime : grade == "B" ? color.yellow : grade == "C" ? color.orange : color.gray

    table.cell(infoTable, 0, 0, "4P STRATEGY", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, grade + " " + direction, text_color=color.white, text_size=size.small, bgcolor=gradeColor)

    table.cell(infoTable, 0, 1, "Points", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 1, str.tostring(pts, "#") + "/12", text_color=color.white, text_size=size.tiny)

    table.cell(infoTable, 0, 2, "P1 Structure", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 2, str.tostring(direction == "LONG" ? p1_long_pts : p1_short_pts, "#") + "/3", text_color=color.white, text_size=size.tiny)

    table.cell(infoTable, 0, 3, "P2 Bias", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 3, str.tostring(direction == "LONG" ? p2_long_pts : p2_short_pts, "#") + "/3", text_color=color.white, text_size=size.tiny)

    table.cell(infoTable, 0, 4, "P3 Momentum", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 4, str.tostring(direction == "LONG" ? p3_long_pts : p3_short_pts, "#") + "/4", text_color=color.white, text_size=size.tiny)

    table.cell(infoTable, 0, 5, "P4 Volatility", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 5, str.tostring(p4_pts, "#") + "/2", text_color=color.white, text_size=size.tiny)

    table.cell(infoTable, 0, 6, "BBWP", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 6, str.tostring(bbwp, "#.0") + "%", text_color=bluSpectrum ? color.blue : redSpectrum ? color.red : color.white, text_size=size.tiny)

    table.cell(infoTable, 0, 7, "40-4", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 7, str.tostring(stoch_40_4, "#"), text_color=stoch_40_4 > 50 ? color.lime : color.red, text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════
// PLOT HIDDEN VALUES FOR DEBUGGING
// ═══════════════════════════════════════════════════════════════════════════

plot(total_long_pts, "total_long_pts", display=display.none)
plot(total_short_pts, "total_short_pts", display=display.none)
plot(stoch_9_3, "stoch_9_3", display=display.none)
plot(stoch_14_3, "stoch_14_3", display=display.none)
plot(stoch_40_4, "stoch_40_4", display=display.none)
plot(stoch_60_10, "stoch_60_10", display=display.none)
plot(bbwp, "bbwp", display=display.none)
plot(bullish_divergence ? 1 : 0, "bull_div", display=display.none)
plot(bearish_divergence ? 1 : 0, "bear_div", display=display.none)
