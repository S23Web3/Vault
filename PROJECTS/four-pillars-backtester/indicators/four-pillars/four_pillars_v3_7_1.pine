//@version=6
// Four Pillars v3.7.1 Indicator — Fast Churn / Rebate Architecture
// Matches v3.7.1 strategy logic with manual position tracking + alerts
// CHANGES from v3.6 indicator:
//   - Simplified: single position (no separate A/BC tracking)
//   - No AVWAP, no trailing — tight static SL/TP (1.0/1.5 ATR)
//   - B/C can open fresh positions and flip direction
//   - Cooldown (min bars between entries)
//   - Cloud 2 re-entry tracks bars since ANY signal (A/B/C)
//   - Removed: volume flip filter, Cloud 3/4 parallel, AVWAP recovery

indicator("Four Pillars v3.7.1", shorttitle="4Pv3.7.1", overlay=true, max_labels_count=500)

// ═══════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════

grp1 = "═══ STOCHASTIC SETTINGS ═══"
i_crossLevel    = input.int(25, "9-3 Cross Level", minval=10, maxval=40, group=grp1, tooltip="9-3 enters zone below this / above (100-this). Stage 2 fires when 9-3 exits zone.")
i_zoneLevel     = input.int(30, "Others Zone Level", minval=20, maxval=40, group=grp1, tooltip="Other stochs must be below/above this")
i_stageLookback = input.int(10, "Stage Lookback (bars)", minval=3, maxval=30, group=grp1, tooltip="Max bars 9-3 can stay in zone before setup expires.")
i_allowBTrades  = input.bool(true, "Allow B Trades (3/4 stochs)", group=grp1, tooltip="B signal = 3/4 stochs aligned. Can open fresh or add.")
i_allowCTrades  = input.bool(true, "Allow C Trades (2/4 + Cloud 3)", group=grp1, tooltip="C signal = 9-3 + 14-3 + Cloud 3. Can open fresh or add.")
i_bOpenFresh    = input.bool(true, "B/C Can Open Fresh Position", group=grp1, tooltip="ON = B/C signals can enter when flat. OFF = only add to existing A.")
i_cloud2Reentry = input.bool(true, "Cloud 2 Re-entry", group=grp1, tooltip="Price crosses Cloud 2 after a recent rotation = re-enter.")
i_reentryLookback = input.int(10, "Cloud 2 Re-entry Lookback", minval=3, maxval=30, group=grp1)

grp2 = "═══ RIPSTER EMAs ═══"
i_ema5      = input.int(5, "EMA 5 (Cloud 2 Short)", group=grp2)
i_ema12     = input.int(12, "EMA 12 (Cloud 2 Long)", group=grp2)
i_ema34     = input.int(34, "EMA 34 (Cloud 3 Short)", group=grp2)
i_ema50     = input.int(50, "EMA 50 (Cloud 3 Long)", group=grp2)
i_ema72     = input.int(72, "EMA 72 (Cloud 4 Short)", group=grp2)
i_ema89     = input.int(89, "EMA 89 (Cloud 4 Long)", group=grp2)

grp3 = "═══ POSITION MANAGEMENT ═══"
i_atrLen    = input.int(14, "ATR Length", group=grp3)
i_slMult    = input.float(1.0, "SL ATR Mult", step=0.1, minval=0.3, group=grp3, tooltip="SL distance from entry. Tight = fast exit on losers.")
i_tpMult    = input.float(1.5, "TP ATR Mult", step=0.1, minval=0.3, group=grp3, tooltip="TP distance from entry. Tight = take small wins reliably.")
i_useTP     = input.bool(true, "Use Take Profit", group=grp3)
i_cooldown  = input.int(3, "Min Bars Between Entries", minval=0, maxval=20, group=grp3, tooltip="Minimum bars between entries. Prevents rapid-fire flipping.")

grp3b = "═══ ADD SIGNAL SETTINGS ═══"
i_addZoneShort = input.int(70, "Short ADD: 9-3 above", minval=60, maxval=90, group=grp3b)
i_addZoneLong  = input.int(30, "Long ADD: 9-3 below", minval=10, maxval=40, group=grp3b)
i_addMidShort  = input.float(52.0, "Short ADD: 40/60 below", step=1.0, group=grp3b)
i_addMidLong   = input.float(48.0, "Long ADD: 40/60 above", step=1.0, group=grp3b)

grp4 = "═══ FILTERS ═══"
i_useRipster = input.bool(false, "Ripster Cloud Filter", group=grp4)
i_use60D     = input.bool(false, "60-10 D Filter", group=grp4)

grp5 = "═══ VISUALS ═══"
i_showDash   = input.bool(true, "Show Dashboard", group=grp5)
i_showCloud2 = input.bool(false, "Show Cloud 2 (5/12)", group=grp5)
i_showCloud3 = input.bool(false, "Show Cloud 3 (34/50)", group=grp5)
i_showCloud4 = input.bool(false, "Show Cloud 4 (72/89)", group=grp5)

// ═══════════════════════════════════════════════════════════════════════════
// STOCHASTIC CALCULATIONS (RAW K — K smoothing=1)
// ═══════════════════════════════════════════════════════════════════════════

stoch_k(int k_len) =>
    float lowest = ta.lowest(low, k_len)
    float highest = ta.highest(high, k_len)
    highest - lowest == 0 ? 50.0 : 100.0 * (close - lowest) / (highest - lowest)

float stoch_9_3      = stoch_k(9)
float stoch_14_3     = stoch_k(14)
float stoch_40_3     = stoch_k(40)
float stoch_60_10    = stoch_k(60)
float stoch_60_10_d  = ta.sma(stoch_60_10, 10)

// ═══════════════════════════════════════════════════════════════════════════
// RIPSTER CLOUDS
// ═══════════════════════════════════════════════════════════════════════════

float ema5  = ta.ema(close, i_ema5)
float ema12 = ta.ema(close, i_ema12)
bool  cloud2_bull    = ema5 > ema12
float cloud2_top     = math.max(ema5, ema12)
float cloud2_bottom  = math.min(ema5, ema12)
bool  price_cross_above_cloud2 = ta.crossover(close, cloud2_top)
bool  price_cross_below_cloud2 = ta.crossunder(close, cloud2_bottom)

float ema34 = ta.ema(close, i_ema34)
float ema50 = ta.ema(close, i_ema50)
bool  cloud3_bull    = ema34 > ema50
float cloud3_top     = math.max(ema34, ema50)
float cloud3_bottom  = math.min(ema34, ema50)
int   price_pos      = close > cloud3_top ? 1 : close < cloud3_bottom ? -1 : 0

float ema72 = ta.ema(close, i_ema72)
float ema89 = ta.ema(close, i_ema89)
bool  cloud4_bull = ema72 > ema89

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY SIGNAL STATE MACHINE (Stage 1 → Stage 2)
// ═══════════════════════════════════════════════════════════════════════════

float crossLow  = i_crossLevel
float crossHigh = 100 - i_crossLevel
float zoneLow   = i_zoneLevel
float zoneHigh  = 100 - i_zoneLevel

bool ripster_ok_long  = not i_useRipster or cloud3_bull or price_pos >= 0
bool ripster_ok_short = not i_useRipster or not cloud3_bull or price_pos <= 0
bool d_ok_long  = not i_use60D or stoch_60_10_d > 20
bool d_ok_short = not i_use60D or stoch_60_10_d < 80

// --- LONG SETUP ---
var int  long_stage = 0
var int  long_stage1_bar = na
var bool long_14_seen = false
var bool long_40_seen = false
var bool long_60_seen = false

bool long_signal   = false
bool long_signal_b = false
bool long_signal_c = false

if long_stage == 0
    if stoch_9_3 < crossLow
        long_stage      := 1
        long_stage1_bar := bar_index
        long_14_seen    := stoch_14_3 < zoneLow
        long_40_seen    := stoch_40_3 < zoneLow
        long_60_seen    := stoch_60_10 < crossLow

else if long_stage == 1
    if bar_index - long_stage1_bar > i_stageLookback
        long_stage := 0
    else if stoch_9_3 >= crossLow
        int long_others = (long_14_seen ? 1 : 0) + (long_40_seen ? 1 : 0) + (long_60_seen ? 1 : 0)
        if long_others == 3 and ripster_ok_long and d_ok_long
            long_signal := true
        else if long_others >= 2 and i_allowBTrades and ripster_ok_long and d_ok_long
            long_signal_b := true
        else if long_14_seen and i_allowCTrades and price_pos == 1
            long_signal_c := true
        long_stage := 0
    else
        if stoch_14_3 < zoneLow
            long_14_seen := true
        if stoch_40_3 < zoneLow
            long_40_seen := true
        if stoch_60_10 < crossLow
            long_60_seen := true

// --- SHORT SETUP ---
var int  short_stage = 0
var int  short_stage1_bar = na
var bool short_14_seen = false
var bool short_40_seen = false
var bool short_60_seen = false

bool short_signal   = false
bool short_signal_b = false
bool short_signal_c = false

if short_stage == 0
    if stoch_9_3 > crossHigh
        short_stage      := 1
        short_stage1_bar := bar_index
        short_14_seen    := stoch_14_3 > zoneHigh
        short_40_seen    := stoch_40_3 > zoneHigh
        short_60_seen    := stoch_60_10 > crossHigh

else if short_stage == 1
    if bar_index - short_stage1_bar > i_stageLookback
        short_stage := 0
    else if stoch_9_3 <= crossHigh
        int short_others = (short_14_seen ? 1 : 0) + (short_40_seen ? 1 : 0) + (short_60_seen ? 1 : 0)
        if short_others == 3 and ripster_ok_short and d_ok_short
            short_signal := true
        else if short_others >= 2 and i_allowBTrades and ripster_ok_short and d_ok_short
            short_signal_b := true
        else if short_14_seen and i_allowCTrades and price_pos == -1
            short_signal_c := true
        short_stage := 0
    else
        if stoch_14_3 > zoneHigh
            short_14_seen := true
        if stoch_40_3 > zoneHigh
            short_40_seen := true
        if stoch_60_10 > crossHigh
            short_60_seen := true

bool others_oversold  = stoch_14_3 < zoneLow and stoch_40_3 < zoneLow and stoch_60_10 < crossLow
bool others_overbought = stoch_14_3 > zoneHigh and stoch_40_3 > zoneHigh and stoch_60_10 > crossHigh

// ═══════════════════════════════════════════════════════════════════════════
// CLOUD 2 RE-ENTRY TRACKING
// Tracks bars since any signal (A, B, or C) for re-entry eligibility
// ═══════════════════════════════════════════════════════════════════════════

var int bars_since_long  = 999
var int bars_since_short = 999

if long_signal or long_signal_b or long_signal_c
    bars_since_long := 0
else
    bars_since_long := bars_since_long + 1

if short_signal or short_signal_b or short_signal_c
    bars_since_short := 0
else
    bars_since_short := bars_since_short + 1

bool recent_long  = bars_since_long <= i_reentryLookback and bars_since_long > 0
bool recent_short = bars_since_short <= i_reentryLookback and bars_since_short > 0

bool any_long_signal  = long_signal or long_signal_b or long_signal_c
bool any_short_signal = short_signal or short_signal_b or short_signal_c

bool reentry_long  = i_cloud2Reentry and price_cross_above_cloud2 and recent_long and not any_long_signal
bool reentry_short = i_cloud2Reentry and price_cross_below_cloud2 and recent_short and not any_short_signal

// ADD signals (informational, fires when in position)
bool add_long_trigger  = ta.crossover(stoch_9_3, i_addZoneLong) and stoch_40_3 > i_addMidLong and stoch_60_10 > i_addMidLong
bool add_short_trigger = ta.crossunder(stoch_9_3, i_addZoneShort) and stoch_40_3 < i_addMidShort and stoch_60_10 < i_addMidShort

// ═══════════════════════════════════════════════════════════════════════════
// POSITION STATE
// ═══════════════════════════════════════════════════════════════════════════

float atr = ta.atr(i_atrLen)

var bool   inPosition = false
var string posDir     = "FLAT"
var float  entryPrice = na
var float  current_sl = na
var float  current_tp = na
var int    entryBar   = na
var int    add_count  = 0
var string tradeGrade = ""
var int    tradeCount = 0

// Per-bar event flags
bool exitSL = false
bool exitTP = false
bool didAdd = false

// ═══════════════════════════════════════════════════════════════════════════
// EXIT CHECKS (before entries so we can re-enter same bar)
// ═══════════════════════════════════════════════════════════════════════════

string exitPosDir = ""

if inPosition
    if posDir == "LONG" and low <= current_sl
        exitSL := true
    else if posDir == "SHORT" and high >= current_sl
        exitSL := true
    if not exitSL and not na(current_tp)
        if posDir == "LONG" and high >= current_tp
            exitTP := true
        else if posDir == "SHORT" and low <= current_tp
            exitTP := true
    if exitSL or exitTP
        exitPosDir := posDir
        inPosition := false
        posDir     := "FLAT"
        entryPrice := na
        current_sl := na
        current_tp := na
        add_count  := 0
        tradeGrade := ""
        tradeCount += 1
        // entryBar NOT reset — cooldown needs it to persist

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY LOGIC
// ═══════════════════════════════════════════════════════════════════════════

bool isFlat = not inPosition

// Cooldown gate
bool cooldownOK = na(entryBar) or (bar_index - entryBar >= i_cooldown)

// Consolidated entry signals (all gated by cooldown)
bool enter_long_a  = long_signal and (isFlat or posDir == "SHORT") and cooldownOK
bool enter_short_a = short_signal and (isFlat or posDir == "LONG") and cooldownOK

bool enter_long_bc  = (long_signal_b or long_signal_c) and ((i_bOpenFresh and isFlat) or (not isFlat and posDir == "LONG")) and cooldownOK
bool enter_short_bc = (short_signal_b or short_signal_c) and ((i_bOpenFresh and isFlat) or (not isFlat and posDir == "SHORT")) and cooldownOK

bool flip_long_bc  = (long_signal_b or long_signal_c) and i_bOpenFresh and not isFlat and posDir == "SHORT" and cooldownOK
bool flip_short_bc = (short_signal_b or short_signal_c) and i_bOpenFresh and not isFlat and posDir == "LONG" and cooldownOK

bool enter_long_re  = reentry_long and isFlat and cooldownOK
bool enter_short_re = reentry_short and isFlat and cooldownOK

// Priority: A flip > A new > BC flip > BC new/add > Re-entry
bool didEnter = false
bool didFlip  = false

if enter_long_a
    if not isFlat and posDir == "SHORT"
        didFlip    := true
        tradeCount += 1
    inPosition := true
    posDir     := "LONG"
    entryPrice := close
    entryBar   := bar_index
    current_sl := close - (i_slMult * atr)
    current_tp := i_useTP ? close + (i_tpMult * atr) : na
    add_count  := 0
    tradeGrade := "A"
    didEnter   := true

else if enter_short_a
    if not isFlat and posDir == "LONG"
        didFlip    := true
        tradeCount += 1
    inPosition := true
    posDir     := "SHORT"
    entryPrice := close
    entryBar   := bar_index
    current_sl := close + (i_slMult * atr)
    current_tp := i_useTP ? close - (i_tpMult * atr) : na
    add_count  := 0
    tradeGrade := "A"
    didEnter   := true

else if flip_long_bc
    tradeCount += 1
    inPosition := true
    posDir     := "LONG"
    entryPrice := close
    entryBar   := bar_index
    current_sl := close - (i_slMult * atr)
    current_tp := i_useTP ? close + (i_tpMult * atr) : na
    add_count  := 0
    tradeGrade := long_signal_b ? "B" : "C"
    didEnter   := true
    didFlip    := true

else if flip_short_bc
    tradeCount += 1
    inPosition := true
    posDir     := "SHORT"
    entryPrice := close
    entryBar   := bar_index
    current_sl := close + (i_slMult * atr)
    current_tp := i_useTP ? close - (i_tpMult * atr) : na
    add_count  := 0
    tradeGrade := short_signal_b ? "B" : "C"
    didEnter   := true
    didFlip    := true

else if enter_long_bc and isFlat
    inPosition := true
    posDir     := "LONG"
    entryPrice := close
    entryBar   := bar_index
    current_sl := close - (i_slMult * atr)
    current_tp := i_useTP ? close + (i_tpMult * atr) : na
    add_count  := 0
    tradeGrade := long_signal_b ? "B" : "C"
    didEnter   := true

else if enter_short_bc and isFlat
    inPosition := true
    posDir     := "SHORT"
    entryPrice := close
    entryBar   := bar_index
    current_sl := close + (i_slMult * atr)
    current_tp := i_useTP ? close - (i_tpMult * atr) : na
    add_count  := 0
    tradeGrade := short_signal_b ? "B" : "C"
    didEnter   := true

else if enter_long_re
    inPosition := true
    posDir     := "LONG"
    entryPrice := close
    entryBar   := bar_index
    current_sl := close - (i_slMult * atr)
    current_tp := i_useTP ? close + (i_tpMult * atr) : na
    add_count  := 0
    tradeGrade := "R"
    didEnter   := true

else if enter_short_re
    inPosition := true
    posDir     := "SHORT"
    entryPrice := close
    entryBar   := bar_index
    current_sl := close + (i_slMult * atr)
    current_tp := i_useTP ? close - (i_tpMult * atr) : na
    add_count  := 0
    tradeGrade := "R"
    didEnter   := true

// ADD signals (informational count only)
else if inPosition and posDir == "LONG" and add_long_trigger
    add_count += 1
    didAdd    := true
else if inPosition and posDir == "SHORT" and add_short_trigger
    add_count += 1
    didAdd    := true

// ═══════════════════════════════════════════════════════════════════════════
// VISUALS
// ═══════════════════════════════════════════════════════════════════════════

// SL / TP lines
plot(inPosition ? current_sl : na, "Stop Loss", color.red, 2, plot.style_linebr)
plot(inPosition and not na(current_tp) ? current_tp : na, "Take Profit", color.green, 1, plot.style_linebr)

// Entry markers
bool didEnterLong  = didEnter and posDir == "LONG"
bool didEnterShort = didEnter and posDir == "SHORT"

plotshape(didEnterLong and tradeGrade == "A", "Long A", shape.triangleup, location.belowbar, color.lime, size=size.normal)
plotshape(didEnterShort and tradeGrade == "A", "Short A", shape.triangledown, location.abovebar, color.red, size=size.normal)
plotshape(didEnterLong and (tradeGrade == "B" or tradeGrade == "C"), "Long BC", shape.triangleup, location.belowbar, #80ff80, size=size.small, text="BC", textcolor=#80ff80)
plotshape(didEnterShort and (tradeGrade == "B" or tradeGrade == "C"), "Short BC", shape.triangledown, location.abovebar, #ff8080, size=size.small, text="BC", textcolor=#ff8080)
plotshape(didEnterLong and tradeGrade == "R", "Long Re-entry", shape.triangleup, location.belowbar, color.teal, size=size.small, text="RE", textcolor=color.teal)
plotshape(didEnterShort and tradeGrade == "R", "Short Re-entry", shape.triangledown, location.abovebar, color.teal, size=size.small, text="RE", textcolor=color.teal)
plotshape(didAdd and posDir == "LONG", "Add Long", shape.triangleup, location.belowbar, #00cc00, size=size.tiny, text="ADD", textcolor=#00cc00)
plotshape(didAdd and posDir == "SHORT", "Add Short", shape.triangledown, location.abovebar, #cc0000, size=size.tiny, text="ADD", textcolor=#cc0000)

// Exit labels
if exitSL and exitPosDir != ""
    if exitPosDir == "LONG"
        label.new(bar_index, high, "SL", color=color.red, textcolor=color.white, style=label.style_label_up, size=size.tiny)
    else
        label.new(bar_index, low, "SL", color=color.red, textcolor=color.white, style=label.style_label_down, size=size.tiny)

if exitTP and exitPosDir != ""
    if exitPosDir == "LONG"
        label.new(bar_index, high, "TP", color=color.green, textcolor=color.white, style=label.style_label_up, size=size.tiny)
    else
        label.new(bar_index, low, "TP", color=color.green, textcolor=color.white, style=label.style_label_down, size=size.tiny)

// Clouds
pC2a = plot(i_showCloud2 ? ema5 : na, "EMA 5", color.new(color.teal, 70))
pC2b = plot(i_showCloud2 ? ema12 : na, "EMA 12", color.new(color.teal, 70))
fill(pC2a, pC2b, cloud2_bull ? color.new(color.teal, 85) : color.new(color.maroon, 85))

pC3a = plot(i_showCloud3 ? ema34 : na, "EMA 34", color.new(color.blue, 70))
pC3b = plot(i_showCloud3 ? ema50 : na, "EMA 50", color.new(color.blue, 70))
fill(pC3a, pC3b, cloud3_bull ? color.new(color.green, 85) : color.new(color.red, 85))

pC4a = plot(i_showCloud4 ? ema72 : na, "EMA 72", color.new(color.purple, 70))
pC4b = plot(i_showCloud4 ? ema89 : na, "EMA 89", color.new(color.purple, 70))
fill(pC4a, pC4b, cloud4_bull ? color.new(color.green, 90) : color.new(color.red, 90))

// ═══════════════════════════════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════

var table dash = table.new(position.top_right, 2, 12, bgcolor=color.new(#1e222d, 10))

if i_showDash and barstate.islast
    table.cell(dash, 0, 0, "4P v3.7.1", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, posDir, text_color=posDir == "LONG" ? color.lime : posDir == "SHORT" ? color.red : color.gray, text_size=size.small)

    table.cell(dash, 0, 1, "9-3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 1, str.tostring(stoch_9_3, "#.0"), text_color=stoch_9_3 < crossLow ? color.lime : stoch_9_3 > crossHigh ? color.red : color.white, text_size=size.tiny)

    table.cell(dash, 0, 2, "14-3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 2, str.tostring(stoch_14_3, "#.0"), text_color=stoch_14_3 < zoneLow ? color.lime : stoch_14_3 > zoneHigh ? color.red : color.white, text_size=size.tiny)

    table.cell(dash, 0, 3, "40-3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(stoch_40_3, "#.0"), text_color=stoch_40_3 < zoneLow ? color.lime : stoch_40_3 > zoneHigh ? color.red : color.white, text_size=size.tiny)

    table.cell(dash, 0, 4, "60-10", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 4, str.tostring(stoch_60_10, "#.0"), text_color=stoch_60_10 < zoneLow ? color.lime : stoch_60_10 > zoneHigh ? color.red : color.white, text_size=size.tiny)

    string allInZone = others_oversold ? "ALL < " + str.tostring(zoneLow, "#") : others_overbought ? "ALL > " + str.tostring(zoneHigh, "#") : "---"
    color zoneColor = others_oversold ? color.lime : others_overbought ? color.red : color.gray
    table.cell(dash, 0, 5, "Zone", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 5, allInZone, text_color=zoneColor, text_size=size.tiny)

    table.cell(dash, 0, 6, "Cloud3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 6, cloud3_bull ? "BULL" : "BEAR", text_color=cloud3_bull ? color.lime : color.red, text_size=size.tiny)

    table.cell(dash, 0, 7, "Cloud2", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 7, cloud2_bull ? "BULL" : "BEAR", text_color=cloud2_bull ? color.lime : color.red, text_size=size.tiny)

    table.cell(dash, 0, 8, "SL/TP", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 8, str.tostring(i_slMult, "#.#") + " / " + str.tostring(i_tpMult, "#.#") + " ATR", text_color=color.white, text_size=size.tiny)

    string gradeStr = inPosition ? tradeGrade + (add_count > 0 ? "+" + str.tostring(add_count) : "") : "---"
    table.cell(dash, 0, 9, "Grade", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 9, gradeStr, text_color=inPosition ? color.white : color.gray, text_size=size.tiny)

    string dStr = str.tostring(stoch_60_10_d, "#.0")
    color dColor = stoch_60_10_d > 20 and stoch_60_10_d < 80 ? color.lime : color.orange
    table.cell(dash, 0, 10, "60 D", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 10, dStr, text_color=dColor, text_size=size.tiny)

    table.cell(dash, 0, 11, "Trades", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 11, str.tostring(tradeCount), text_color=color.white, text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════

alertcondition(didEnterLong and tradeGrade == "A", "Long A Entry", "4Pv3.7.1: LONG A entry — 4/4 stoch alignment")
alertcondition(didEnterShort and tradeGrade == "A", "Short A Entry", "4Pv3.7.1: SHORT A entry — 4/4 stoch alignment")
alertcondition(didEnterLong and (tradeGrade == "B" or tradeGrade == "C"), "Long BC Entry", "4Pv3.7.1: LONG BC entry")
alertcondition(didEnterShort and (tradeGrade == "B" or tradeGrade == "C"), "Short BC Entry", "4Pv3.7.1: SHORT BC entry")
alertcondition(didEnterLong and tradeGrade == "R", "Long Re-entry", "4Pv3.7.1: LONG Cloud 2 re-entry")
alertcondition(didEnterShort and tradeGrade == "R", "Short Re-entry", "4Pv3.7.1: SHORT Cloud 2 re-entry")
alertcondition(didAdd and posDir == "LONG", "Add Long", "4Pv3.7.1: ADD to LONG — 9-3 pullback, trend intact")
alertcondition(didAdd and posDir == "SHORT", "Add Short", "4Pv3.7.1: ADD to SHORT — 9-3 pullback, trend intact")
alertcondition(exitSL, "Stop Loss Hit", "4Pv3.7.1: Stop loss hit")
alertcondition(exitTP, "Take Profit Hit", "4Pv3.7.1: Take profit hit")

// ═══════════════════════════════════════════════════════════════════════════
// HIDDEN PLOTS (for JSON alerts / external consumption)
// ═══════════════════════════════════════════════════════════════════════════

plot(stoch_9_3, "stoch_9_3", display=display.none)
plot(stoch_14_3, "stoch_14_3", display=display.none)
plot(stoch_40_3, "stoch_40_3", display=display.none)
plot(stoch_60_10, "stoch_60_10", display=display.none)
plot(stoch_60_10_d, "stoch_60_10_d", display=display.none)
plot(inPosition ? current_sl : na, "current_sl_val", display=display.none)
plot(inPosition and not na(current_tp) ? current_tp : na, "current_tp_val", display=display.none)
