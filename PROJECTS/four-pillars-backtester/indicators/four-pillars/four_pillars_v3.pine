//@version=6
// Four Pillars v3.3 - Clean Quad Rotation Logic
// Entry: 9-3 crosses zone, ALL others in zone (3-bar lookback)
// Exit: If stochastics don't follow within 5 bars
// Filters: Ripster cloud, 60-10 D line position
// v3.3: 60-10 D filter with fixed 20/80 thresholds

indicator("Four Pillars v3.3", shorttitle="4Pv3.3", overlay=true)

// ═══════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════

grp1 = "═══ STOCHASTIC SETTINGS ═══"
i_crossLevel = input.int(20, "9-3 Cross Level", minval=10, maxval=40, group=grp1, tooltip="9-3 must cross this level (20 = cross 20/80)")
i_zoneLevel = input.int(30, "Others Zone Level", minval=20, maxval=40, group=grp1, tooltip="Other stochs must be below/above this (30 = all < 30 or > 70)")
i_rotationBars = input.int(5, "Rotation Check Bars", minval=3, maxval=10, group=grp1)

grp2 = "═══ RIPSTER EMAs ═══"
i_ema34 = input.int(34, "EMA 34", group=grp2)
i_ema50 = input.int(50, "EMA 50", group=grp2)

grp3 = "═══ POSITION MANAGEMENT ═══"
i_atrLen = input.int(14, "ATR Length", group=grp3)
i_slMult = input.float(2.0, "Stop Loss ATR Mult", group=grp3)
i_tpMult = input.float(4.0, "Take Profit ATR Mult", group=grp3)

grp4 = "═══ FILTERS ═══"
i_useRipster = input.bool(false, "Use Ripster Filter", group=grp4, tooltip="Enable to require Ripster cloud alignment")
i_use60D = input.bool(false, "Use 60-10 D Filter", group=grp4, tooltip="Require 60-10 D line: D>20 for long, D<80 for short (fixed thresholds)")

grp5 = "═══ VISUALS ═══"
i_showDash = input.bool(true, "Show Dashboard", group=grp5)

// ═══════════════════════════════════════════════════════════════════════════
// STOCHASTIC CALCULATIONS
// Matches TradingView standard: K Length, K Smoothing=1, D Smoothing
// We track the K line (blue bar) which is the raw stochastic
// ═══════════════════════════════════════════════════════════════════════════

// Standard stochastic K line (K smoothing = 1 = raw)
stoch_k_line(int k_len) =>
    float lowest = ta.lowest(low, k_len)
    float highest = ta.highest(high, k_len)
    highest - lowest == 0 ? 50.0 : 100.0 * (close - lowest) / (highest - lowest)

// Calculate all 4 stochastics - K line values (what you see as blue bar)
// Settings match: K Length, K Smoothing=1 (raw), D Smoothing=3/10
float stoch_9_3 = stoch_k_line(9)      // 9-3: K=9, raw K line
float stoch_14_3 = stoch_k_line(14)    // 14-3: K=14, raw K line
float stoch_40_3 = stoch_k_line(40)    // 40-3: K=40, raw K line
float stoch_60_10 = stoch_k_line(60)   // 60-10: K=60, raw K line

// 60-10 D line (orange line) for D filter
float stoch_60_10_d = ta.sma(stoch_60_10, 10)  // D = SMA of K with period 10

// ═══════════════════════════════════════════════════════════════════════════
// RIPSTER CLOUD
// ═══════════════════════════════════════════════════════════════════════════

float ema34 = ta.ema(close, i_ema34)
float ema50 = ta.ema(close, i_ema50)
bool cloud_bull = ema34 > ema50
float cloud_top = math.max(ema34, ema50)
float cloud_bottom = math.min(ema34, ema50)
int price_pos = close > cloud_top ? 1 : close < cloud_bottom ? -1 : 0

// ═══════════════════════════════════════════════════════════════════════════
// QUAD ROTATION ENTRY LOGIC
// ═══════════════════════════════════════════════════════════════════════════

// 9-3 crossing thresholds
float crossLow = i_crossLevel          // 20 by default
float crossHigh = 100 - i_crossLevel   // 80 by default

// Others in zone thresholds
float zoneLow = i_zoneLevel            // 30 by default
float zoneHigh = 100 - i_zoneLevel     // 70 by default

// 9-3 crossing the zone (THE TRIGGER)
bool cross_up = ta.crossover(stoch_9_3, crossLow)
bool cross_down = ta.crossunder(stoch_9_3, crossHigh)

// ALL others must be in zone when 9-3 triggers (or within last 3 bars)
bool others_oversold_now = stoch_14_3 < zoneLow and stoch_40_3 < zoneLow and stoch_60_10 < zoneLow
bool others_oversold_1 = stoch_14_3[1] < zoneLow and stoch_40_3[1] < zoneLow and stoch_60_10[1] < zoneLow
bool others_oversold_2 = stoch_14_3[2] < zoneLow and stoch_40_3[2] < zoneLow and stoch_60_10[2] < zoneLow
bool others_oversold = others_oversold_now or others_oversold_1 or others_oversold_2

bool others_overbought_now = stoch_14_3 > zoneHigh and stoch_40_3 > zoneHigh and stoch_60_10 > zoneHigh
bool others_overbought_1 = stoch_14_3[1] > zoneHigh and stoch_40_3[1] > zoneHigh and stoch_60_10[1] > zoneHigh
bool others_overbought_2 = stoch_14_3[2] > zoneHigh and stoch_40_3[2] > zoneHigh and stoch_60_10[2] > zoneHigh
bool others_overbought = others_overbought_now or others_overbought_1 or others_overbought_2

// Ripster filter (optional - toggle in settings)
bool ripster_ok_long = not i_useRipster or cloud_bull or price_pos >= 0
bool ripster_ok_short = not i_useRipster or not cloud_bull or price_pos <= 0

// 60-10 D line filter - fixed thresholds (not configurable)
// For longs: D must be above 20 (has room to rise)
// For shorts: D must be below 80 (has room to fall)
bool d_ok_long = not i_use60D or stoch_60_10_d > 20
bool d_ok_short = not i_use60D or stoch_60_10_d < 80

// ENTRY SIGNALS
bool long_signal = cross_up and others_oversold and ripster_ok_long and d_ok_long
bool short_signal = cross_down and others_overbought and ripster_ok_short and d_ok_short

// ═══════════════════════════════════════════════════════════════════════════
// ROTATION TRACKING (are stochastics following?)
// ═══════════════════════════════════════════════════════════════════════════

// Check if stochastics are moving in the right direction
bool stochs_rising = stoch_14_3 > stoch_14_3[1] and stoch_40_3 > stoch_40_3[1]
bool stochs_falling = stoch_14_3 < stoch_14_3[1] and stoch_40_3 < stoch_40_3[1]

// ═══════════════════════════════════════════════════════════════════════════
// POSITION MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════

float atr = ta.atr(i_atrLen)

var bool inPosition = false
var string posDir = "FLAT"
var float entryPrice = na
var float stopLoss = na
var float takeProfit = na
var int entryBar = na

// Check exits first
bool hitStop = false
bool hitTP = false
bool rotationFailed = false

if inPosition
    hitStop := posDir == "LONG" ? low <= stopLoss : high >= stopLoss
    hitTP := posDir == "LONG" ? high >= takeProfit : low <= takeProfit

    // Check rotation after 3-5 bars
    int bars = bar_index - entryBar
    if bars >= 3 and bars <= i_rotationBars
        if posDir == "LONG" and not stochs_rising
            rotationFailed := true
        if posDir == "SHORT" and not stochs_falling
            rotationFailed := true

    if hitStop or hitTP or rotationFailed
        inPosition := false
        posDir := "FLAT"
        entryPrice := na
        stopLoss := na
        takeProfit := na
        entryBar := na

// New entries
if long_signal and not inPosition
    inPosition := true
    posDir := "LONG"
    entryPrice := close
    entryBar := bar_index
    // Tighter stop if trading under the cloud (counter-trend)
    float slMult = price_pos < 0 ? 1.0 : i_slMult
    stopLoss := close - (slMult * atr)
    takeProfit := close + (i_tpMult * atr)

else if short_signal and not inPosition
    inPosition := true
    posDir := "SHORT"
    entryPrice := close
    entryBar := bar_index
    // Tighter stop if trading above the cloud (counter-trend)
    float slMult = price_pos > 0 ? 1.0 : i_slMult
    stopLoss := close + (slMult * atr)
    takeProfit := close - (i_tpMult * atr)

// ═══════════════════════════════════════════════════════════════════════════
// VISUALS
// ═══════════════════════════════════════════════════════════════════════════

// Track actual entries (for visual markers)
bool didEnterLong = inPosition and posDir == "LONG" and (not inPosition[1] or posDir[1] != "LONG")
bool didEnterShort = inPosition and posDir == "SHORT" and (not inPosition[1] or posDir[1] != "SHORT")

// Entry markers - show when we actually entered
plotshape(didEnterLong, "Long", shape.triangleup, location.belowbar, color.lime, size=size.normal)
plotshape(didEnterShort, "Short", shape.triangledown, location.abovebar, color.red, size=size.normal)

// Position lines
plot(inPosition ? stopLoss : na, "Stop", color.red, 2, plot.style_linebr)
plot(inPosition ? takeProfit : na, "TP", color.green, 1, plot.style_linebr)

// Cloud
p1 = plot(ema34, "EMA34", color.new(color.blue, 80))
p2 = plot(ema50, "EMA50", color.new(color.blue, 80))
fill(p1, p2, cloud_bull ? color.new(color.green, 90) : color.new(color.red, 90))

// ═══════════════════════════════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════

if i_showDash and barstate.islast
    var table dash = table.new(position.top_right, 2, 9, bgcolor=color.new(#1e222d, 10))

    table.cell(dash, 0, 0, "4P v3.3", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, posDir, text_color=posDir == "LONG" ? color.lime : posDir == "SHORT" ? color.red : color.gray)

    table.cell(dash, 0, 1, "9-3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 1, str.tostring(stoch_9_3, "#.0"), text_color=stoch_9_3 < crossLow ? color.lime : stoch_9_3 > crossHigh ? color.red : color.white, text_size=size.tiny)

    table.cell(dash, 0, 2, "14-3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 2, str.tostring(stoch_14_3, "#.0"), text_color=stoch_14_3 < zoneLow ? color.lime : stoch_14_3 > zoneHigh ? color.red : color.white, text_size=size.tiny)

    table.cell(dash, 0, 3, "40-3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(stoch_40_3, "#.0"), text_color=stoch_40_3 < zoneLow ? color.lime : stoch_40_3 > zoneHigh ? color.red : color.white, text_size=size.tiny)

    table.cell(dash, 0, 4, "60-10", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 4, str.tostring(stoch_60_10, "#.0"), text_color=stoch_60_10 < zoneLow ? color.lime : stoch_60_10 > zoneHigh ? color.red : color.white, text_size=size.tiny)

    string allInZone = others_oversold ? "ALL < " + str.tostring(zoneLow, "#") : others_overbought ? "ALL > " + str.tostring(zoneHigh, "#") : "---"
    color zoneColor = others_oversold ? color.lime : others_overbought ? color.red : color.gray
    table.cell(dash, 0, 5, "Zone", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 5, allInZone, text_color=zoneColor, text_size=size.tiny)

    table.cell(dash, 0, 6, "Cloud", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 6, cloud_bull ? "BULL" : "BEAR", text_color=cloud_bull ? color.lime : color.red, text_size=size.tiny)

    string followStr = inPosition ? (posDir == "LONG" ? (stochs_rising ? "YES" : "NO") : (stochs_falling ? "YES" : "NO")) : "---"
    color followColor = followStr == "YES" ? color.lime : followStr == "NO" ? color.red : color.gray
    table.cell(dash, 0, 7, "Follow", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 7, followStr, text_color=followColor, text_size=size.tiny)

    // 60-10 D line status (>20 for long, <80 for short - fixed thresholds)
    string dStr = str.tostring(stoch_60_10_d, "#.0")
    color dColor = stoch_60_10_d > 20 and stoch_60_10_d < 80 ? color.lime : color.orange
    table.cell(dash, 0, 8, "60 D", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 8, dStr, text_color=dColor, text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════

alertcondition(long_signal, "Long Entry", "4Pv3: LONG - All stochs oversold, 9-3 crossing up")
alertcondition(short_signal, "Short Entry", "4Pv3: SHORT - All stochs overbought, 9-3 crossing down")
alertcondition(rotationFailed, "Rotation Failed", "4Pv3: Exit - stochastics not following")

// ═══════════════════════════════════════════════════════════════════════════
// HIDDEN PLOTS
// ═══════════════════════════════════════════════════════════════════════════

plot(stoch_9_3, "stoch_9_3", display=display.none)
plot(stoch_14_3, "stoch_14_3", display=display.none)
plot(stoch_40_3, "stoch_40_3", display=display.none)
plot(stoch_60_10, "stoch_60_10", display=display.none)
plot(stoch_60_10_d, "stoch_60_10_d", display=display.none)
plot(stoch_60_10_d > 20 and stoch_60_10_d < 80 ? 1 : 0, "stoch_60_d_valid", display=display.none)
plot(others_oversold ? 1 : 0, "all_oversold", display=display.none)
plot(others_overbought ? 1 : 0, "all_overbought", display=display.none)
plot(inPosition ? 1 : 0, "in_position", display=display.none)
