//@version=6
// Four Pillars v3.5.1 Strategy - Backtesting Version
// - RAW K stochastics (K smoothing=1, matches external Stoch indicators)
// - Stage-based entry: Stage 1 = 9-3 enters zone, Stage 2 = 9-3 exits zone
// - Trail activation gate (Cloud 3/4 cross), no phased system
// - A trades (4/4 stoch) can flip direction; B/C add to existing A same direction
// - $500 per entry at 20x leverage, pyramiding=3 (A + B + C max)
// - Entry fills on NEXT candle (process_orders_on_close=false)
// - ADDs are informational only

strategy("Four Pillars v3.5.1 Strategy", shorttitle="4Pv3.5.1-S", overlay=true,
         initial_capital=10000, default_qty_type=strategy.cash,
         default_qty_value=500, margin_long=5, margin_short=5,
         commission_type=strategy.commission.percent,
         commission_value=0.1, pyramiding=3, process_orders_on_close=false,
         max_labels_count=500)

// ═══════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════

grp1 = "═══ STOCHASTIC SETTINGS ═══"
i_crossLevel = input.int(25, "9-3 Cross Level", minval=10, maxval=40, group=grp1, tooltip="9-3 enters zone below this / above (100-this). Stage 2 fires when 9-3 exits zone.")
i_zoneLevel = input.int(30, "Others Zone Level", minval=20, maxval=40, group=grp1, tooltip="Other stochs must be below/above this")
i_stageLookback = input.int(10, "Stage Lookback (bars)", minval=3, maxval=30, group=grp1, tooltip="Max bars 9-3 can stay in zone before setup expires. Others must enter zone within this window.")
i_allowBTrades = input.bool(false, "Allow B Trades (3/4 stochs)", group=grp1, tooltip="Add $500 when 3/4 stochs aligned. Only when A trade is open in same direction.")
i_allowCTrades = input.bool(false, "Allow C Trades (2/4 + Cloud 3)", group=grp1, tooltip="Add $500 when 9-3 + 14-3 aligned + Cloud 3. Only when A trade is open in same direction.")
i_cloud2Reentry = input.bool(true, "Cloud 2 Re-entry (A trade)", group=grp1, tooltip="Price crosses Cloud 2 after a recent A rotation (4/4 stochs) = A trade. SL trails Cloud 3, no TP.")
i_reentryLookback = input.int(10, "Cloud 2 Re-entry Lookback", minval=3, maxval=30, group=grp1, tooltip="How many bars back to look for a prior A rotation signal")

grp2 = "═══ RIPSTER EMAs ═══"
i_ema5 = input.int(5, "EMA 5 (Cloud 2 Short)", group=grp2)
i_ema12 = input.int(12, "EMA 12 (Cloud 2 Long)", group=grp2)
i_ema34 = input.int(34, "EMA 34 (Cloud 3 Short)", group=grp2)
i_ema50 = input.int(50, "EMA 50 (Cloud 3 Long)", group=grp2)
i_ema72 = input.int(72, "EMA 72 (Cloud 4 Short)", group=grp2)
i_ema89 = input.int(89, "EMA 89 (Cloud 4 Long)", group=grp2)

grp3 = "═══ POSITION MANAGEMENT ═══"
i_atrLen = input.int(14, "ATR Length", group=grp3)
i_slMult = input.float(2.0, "Initial SL ATR Mult", step=0.1, group=grp3, tooltip="SL distance from entry in ATR units. Trail activates after Cloud 3 crosses Cloud 4.")
i_tpMult = input.float(4.0, "Initial TP ATR Mult", step=0.1, group=grp3)
i_useTP = input.bool(true, "Use Take Profit", group=grp3, tooltip="When OFF, no TP is set — trades exit only via SL trail")
i_useRaisingSL = input.bool(true, "Use Raising Stop Loss", group=grp3, tooltip="When ON, SL trails Cloud 3 (34/50) ± 1 ATR after Cloud 3/4 cross. When OFF, SL stays static at entry.")

grp3b = "═══ ADD SIGNAL SETTINGS ═══"
i_addZoneShort = input.int(70, "Short ADD: 9-3 must enter zone above", minval=60, maxval=90, group=grp3b, tooltip="9-3 dips above this, then exits below = short ADD")
i_addZoneLong = input.int(30, "Long ADD: 9-3 must enter zone below", minval=10, maxval=40, group=grp3b, tooltip="9-3 dips below this, then exits above = long ADD")
i_addMidShort = input.float(52.0, "Short ADD: 40/60 must stay below", step=1.0, group=grp3b, tooltip="40-3 and 60-10 must stay below this (bearish bias intact)")
i_addMidLong = input.float(48.0, "Long ADD: 40/60 must stay above", step=1.0, group=grp3b, tooltip="40-3 and 60-10 must stay above this (bullish bias intact)")

grp4 = "═══ FILTERS ═══"
i_useRipster = input.bool(false, "Use Ripster Cloud Filter", group=grp4, tooltip="Require Cloud 3 alignment for entry")
i_use60D = input.bool(false, "Use 60-10 D Filter", group=grp4, tooltip="Require 60-10 D: >20 for long, <80 for short")

grp5 = "═══ VISUALS ═══"
i_showDash = input.bool(true, "Show Dashboard", group=grp5)
i_showCloud2 = input.bool(false, "Show Cloud 2 (5/12)", group=grp5)
i_showCloud3 = input.bool(false, "Show Cloud 3 (34/50)", group=grp5)
i_showCloud4 = input.bool(false, "Show Cloud 4 (72/89)", group=grp5)

// ═══════════════════════════════════════════════════════════════════════════
// STOCHASTIC CALCULATIONS (v3.5.1: RAW K — K smoothing=1, matches external indicators)
// External indicators show "Stoch 9 1 3" = K_period=9, K_smooth=1 (raw), D_smooth=3
// We use raw K for all entry decisions. D line only used for 60-10 crossover filter.
// ═══════════════════════════════════════════════════════════════════════════

// Raw stochastic K line (no smoothing — K smooth = 1)
stoch_k(int k_len) =>
    float lowest = ta.lowest(low, k_len)
    float highest = ta.highest(high, k_len)
    highest - lowest == 0 ? 50.0 : 100.0 * (close - lowest) / (highest - lowest)

float stoch_9_3 = stoch_k(9)      // Raw K, period 9
float stoch_14_3 = stoch_k(14)    // Raw K, period 14
float stoch_40_3 = stoch_k(40)    // Raw K, period 40
float stoch_60_10 = stoch_k(60)   // Raw K, period 60
float stoch_60_10_d = ta.sma(stoch_60_10, 10)  // D line = SMA(K, 10)

// ═══════════════════════════════════════════════════════════════════════════
// RIPSTER CLOUDS (2, 3, 4)
// ═══════════════════════════════════════════════════════════════════════════

// Cloud 2 (5/12) — Fast momentum, re-entry reference
float ema5 = ta.ema(close, i_ema5)
float ema12 = ta.ema(close, i_ema12)
bool cloud2_bull = ema5 > ema12
float cloud2_top = math.max(ema5, ema12)
float cloud2_bottom = math.min(ema5, ema12)
bool price_cross_above_cloud2 = ta.crossover(close, cloud2_top)
bool price_cross_below_cloud2 = ta.crossunder(close, cloud2_bottom)

// Cloud 3 (34/50) — Trail reference, Ripster filter
float ema34 = ta.ema(close, i_ema34)
float ema50 = ta.ema(close, i_ema50)
bool cloud3_bull = ema34 > ema50
float cloud3_top = math.max(ema34, ema50)
float cloud3_bottom = math.min(ema34, ema50)
int price_pos = close > cloud3_top ? 1 : close < cloud3_bottom ? -1 : 0

// Cloud 4 (72/89) — trail activation gate
float ema72 = ta.ema(close, i_ema72)
float ema89 = ta.ema(close, i_ema89)
bool cloud4_bull = ema72 > ema89

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY SIGNAL LOGIC (State Machine: Stage 1 → Stage 2)
// Stage 1: 9-3 enters zone (below crossLow for long, above crossHigh for short)
// Stage 2: 9-3 exits zone — count which others were also in zone during Stage 1
//   3/3 others = A trade (4/4), 2/3 = B trade (3/4), 14-3 only = C trade (2/4)
// ═══════════════════════════════════════════════════════════════════════════

float crossLow = i_crossLevel
float crossHigh = 100 - i_crossLevel
float zoneLow = i_zoneLevel
float zoneHigh = 100 - i_zoneLevel

// Filters (applied at stage 2 trigger)
bool ripster_ok_long = not i_useRipster or cloud3_bull or price_pos >= 0
bool ripster_ok_short = not i_useRipster or not cloud3_bull or price_pos <= 0
bool d_ok_long = not i_use60D or stoch_60_10_d > 20
bool d_ok_short = not i_use60D or stoch_60_10_d < 80

// --- LONG SETUP STATE MACHINE ---
var int long_stage = 0              // 0=waiting, 1=9-3 in oversold zone
var int long_stage1_bar = na        // Bar when 9-3 entered zone
var bool long_14_seen = false       // 14-3 was in zone during stage 1
var bool long_40_seen = false       // 40-3 was in zone during stage 1
var bool long_60_seen = false       // 60-10 was in zone during stage 1

bool long_signal = false
bool long_signal_b = false
bool c_long_base = false

if long_stage == 0
    // Stage 0 → 1: 9-3 enters oversold zone
    if stoch_9_3 < crossLow
        long_stage := 1
        long_stage1_bar := bar_index
        long_14_seen := stoch_14_3 < zoneLow
        long_40_seen := stoch_40_3 < zoneLow
        long_60_seen := stoch_60_10 < crossLow

else if long_stage == 1
    if bar_index - long_stage1_bar > i_stageLookback
        // Expired — setup took too long
        long_stage := 0
    else if stoch_9_3 >= crossLow
        // Stage 2: 9-3 exits oversold = ENTRY TRIGGER
        int long_others = (long_14_seen ? 1 : 0) + (long_40_seen ? 1 : 0) + (long_60_seen ? 1 : 0)

        if long_others == 3 and ripster_ok_long and d_ok_long
            long_signal := true         // A trade (4/4 stochs)
        else if long_others >= 2 and i_allowBTrades and ripster_ok_long and d_ok_long
            long_signal_b := true       // B trade (3/4 stochs)
        else if long_14_seen and i_allowCTrades and price_pos == 1
            c_long_base := true         // C trade (2/4 fast pair + Cloud 3)

        long_stage := 0
    else
        // Still in zone — keep tracking which stochs enter zone
        if stoch_14_3 < zoneLow
            long_14_seen := true
        if stoch_40_3 < zoneLow
            long_40_seen := true
        if stoch_60_10 < crossLow
            long_60_seen := true

// --- SHORT SETUP STATE MACHINE ---
var int short_stage = 0
var int short_stage1_bar = na
var bool short_14_seen = false
var bool short_40_seen = false
var bool short_60_seen = false

bool short_signal = false
bool short_signal_b = false
bool c_short_base = false

if short_stage == 0
    if stoch_9_3 > crossHigh
        short_stage := 1
        short_stage1_bar := bar_index
        short_14_seen := stoch_14_3 > zoneHigh
        short_40_seen := stoch_40_3 > zoneHigh
        short_60_seen := stoch_60_10 > crossHigh

else if short_stage == 1
    if bar_index - short_stage1_bar > i_stageLookback
        short_stage := 0
    else if stoch_9_3 <= crossHigh
        int short_others = (short_14_seen ? 1 : 0) + (short_40_seen ? 1 : 0) + (short_60_seen ? 1 : 0)

        if short_others == 3 and ripster_ok_short and d_ok_short
            short_signal := true
        else if short_others >= 2 and i_allowBTrades and ripster_ok_short and d_ok_short
            short_signal_b := true
        else if short_14_seen and i_allowCTrades and price_pos == -1
            c_short_base := true

        short_stage := 0
    else
        if stoch_14_3 > zoneHigh
            short_14_seen := true
        if stoch_40_3 > zoneHigh
            short_40_seen := true
        if stoch_60_10 > crossHigh
            short_60_seen := true

// Dashboard helper (current state, not entry logic)
bool others_oversold = stoch_14_3 < zoneLow and stoch_40_3 < zoneLow and stoch_60_10 < crossLow
bool others_overbought = stoch_14_3 > zoneHigh and stoch_40_3 > zoneHigh and stoch_60_10 > crossHigh

// Cloud 2 re-entry: price crosses Cloud 2 + A rotation (4/4 stoch) within lookback = A trade
var int bars_since_a_long = 999
var int bars_since_a_short = 999

if long_signal
    bars_since_a_long := 0
else
    bars_since_a_long := bars_since_a_long + 1

if short_signal
    bars_since_a_short := 0
else
    bars_since_a_short := bars_since_a_short + 1

bool recent_a_long = bars_since_a_long <= i_reentryLookback and bars_since_a_long > 0
bool recent_a_short = bars_since_a_short <= i_reentryLookback and bars_since_a_short > 0

bool reentry_long = i_cloud2Reentry and price_cross_above_cloud2 and recent_a_long and not long_signal
bool reentry_short = i_cloud2Reentry and price_cross_below_cloud2 and recent_a_short and not short_signal

// ═══════════════════════════════════════════════════════════════════════════
// ADD SIGNAL DETECTION (informational only — no pyramiding)
// ═══════════════════════════════════════════════════════════════════════════

bool add_short_trigger = ta.crossunder(stoch_9_3, i_addZoneShort) and stoch_40_3 < i_addMidShort and stoch_60_10 < i_addMidShort
bool add_long_trigger = ta.crossover(stoch_9_3, i_addZoneLong) and stoch_40_3 > i_addMidLong and stoch_60_10 > i_addMidLong

// ═══════════════════════════════════════════════════════════════════════════
// POSITION STATE (mirrors indicator exactly)
// ═══════════════════════════════════════════════════════════════════════════

float atr = ta.atr(i_atrLen)

var bool inPosition = false
var string posDir = "FLAT"
var float entryPrice = na
var float current_sl = na
var float current_tp = na
var int entryBar = na
var int add_count = 0
var string tradeGrade = ""
var string lastTradeDir = ""
var bool trailActive = false

// Per-bar event flags (reset each bar)
bool didAdd = false
bool didBCEntry = false

// ═══════════════════════════════════════════════════════════════════════════
// STATE SYNC — strategy.exit() is sole exit handler, sync via position_size
// ═══════════════════════════════════════════════════════════════════════════

if strategy.position_size == 0 and inPosition
    // Strategy engine closed our position (SL or TP hit via strategy.exit)
    lastTradeDir := posDir
    inPosition := false
    posDir := "FLAT"
    entryPrice := na
    current_sl := na
    current_tp := na
    entryBar := na
    add_count := 0
    tradeGrade := ""
    trailActive := false

// ═══════════════════════════════════════════════════════════════════════════
// NEW ENTRIES / ADD
// ═══════════════════════════════════════════════════════════════════════════

// A trades (4/4 stoch): can open new position or flip direction
// B/C trades: only ADD to existing A trade in same direction (pyramiding)
// Re-entry A: only when flat
bool canFlipLong = not inPosition or (inPosition and posDir == "SHORT")
bool canFlipShort = not inPosition or (inPosition and posDir == "LONG")
bool canAddLong = inPosition and posDir == "LONG"
bool canAddShort = inPosition and posDir == "SHORT"

if long_signal and canFlipLong
    // Close existing short if flipping direction
    if inPosition and posDir == "SHORT"
        strategy.close_all("Flip to Long")
    inPosition := true
    posDir := "LONG"
    entryPrice := close
    entryBar := bar_index
    current_sl := close - (i_slMult * atr)
    current_tp := i_useTP ? close + (i_tpMult * atr) : na
    add_count := 0
    tradeGrade := "A"
    trailActive := false

else if short_signal and canFlipShort
    // Close existing long if flipping direction
    if inPosition and posDir == "LONG"
        strategy.close_all("Flip to Short")
    inPosition := true
    posDir := "SHORT"
    entryPrice := close
    entryBar := bar_index
    current_sl := close + (i_slMult * atr)
    current_tp := i_useTP ? close - (i_tpMult * atr) : na
    add_count := 0
    tradeGrade := "A"
    trailActive := false

// Cloud 2 re-entry A trades: only when flat, always trail, never TP
else if reentry_long and not inPosition
    inPosition := true
    posDir := "LONG"
    entryPrice := close
    entryBar := bar_index
    current_sl := close - (i_slMult * atr)
    current_tp := na
    add_count := 0
    tradeGrade := "A"
    trailActive := false

else if reentry_short and not inPosition
    inPosition := true
    posDir := "SHORT"
    entryPrice := close
    entryBar := bar_index
    current_sl := close + (i_slMult * atr)
    current_tp := na
    add_count := 0
    tradeGrade := "A"
    trailActive := false

// B trade: 3/4 stochs — ADD to existing A trade in same direction
else if long_signal_b and canAddLong
    add_count := add_count + 1
    didBCEntry := true

else if short_signal_b and canAddShort
    add_count := add_count + 1
    didBCEntry := true

// C trade: 2/4 fast pair + Cloud 3 — ADD to existing A trade in same direction
else if c_long_base and canAddLong
    add_count := add_count + 1
    didBCEntry := true

else if c_short_base and canAddShort
    add_count := add_count + 1
    didBCEntry := true

// ADD signals (informational only — no new strategy entries)
else if inPosition and posDir == "LONG" and add_long_trigger
    add_count := add_count + 1
    didAdd := true

else if inPosition and posDir == "SHORT" and add_short_trigger
    add_count := add_count + 1
    didAdd := true

// ═══════════════════════════════════════════════════════════════════════════
// TRAIL ACTIVATION (Cloud 3 crosses Cloud 4 = trend confirmed)
// ═══════════════════════════════════════════════════════════════════════════

// Trail activates when ema50 (Cloud 3 slow) crosses ema72 (Cloud 4 fast)
// Once active, stays active for the duration of the trade
if inPosition and not trailActive
    if posDir == "LONG" and ema50 > ema72
        trailActive := true
    else if posDir == "SHORT" and ema50 < ema72
        trailActive := true

// ═══════════════════════════════════════════════════════════════════════════
// CLOUD 3 TRAIL (only when trail is active)
// ═══════════════════════════════════════════════════════════════════════════

if inPosition and i_useRaisingSL and trailActive and bar_index > entryBar
    if posDir == "LONG"
        float new_sl = cloud3_bottom - atr
        if new_sl > current_sl and new_sl < close
            current_sl := new_sl
    else
        float new_sl = cloud3_top + atr
        if new_sl < current_sl and new_sl > close
            current_sl := new_sl

// ═══════════════════════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ═══════════════════════════════════════════════════════════════════════════

// Detect new entries — entryBar == bar_index catches entries on this bar
bool didEnterThisBar = entryBar == bar_index
bool didEnterLong = didEnterThisBar and posDir == "LONG"
bool didEnterShort = didEnterThisBar and posDir == "SHORT"

// Entry orders (A trades + re-entry)
if didEnterLong
    strategy.entry("Long", strategy.long)
if didEnterShort
    strategy.entry("Short", strategy.short)

// B/C entry orders (add to existing A position, same ID = shared SL/TP)
if didBCEntry
    if posDir == "LONG"
        strategy.entry("Long", strategy.long)
    else if posDir == "SHORT"
        strategy.entry("Short", strategy.short)

// Exit orders — strategy.exit() is SOLE exit handler
// Update every bar so trailing SL is reflected
if inPosition and posDir == "LONG"
    if na(current_tp)
        strategy.exit("Exit Long", "Long", stop=current_sl)
    else
        strategy.exit("Exit Long", "Long", stop=current_sl, limit=current_tp)
else if inPosition and posDir == "SHORT"
    if na(current_tp)
        strategy.exit("Exit Short", "Short", stop=current_sl)
    else
        strategy.exit("Exit Short", "Short", stop=current_sl, limit=current_tp)

// ═══════════════════════════════════════════════════════════════════════════
// VISUALS
// ═══════════════════════════════════════════════════════════════════════════

// SL line — yellow=trailing active, orange=waiting for C3/C4 cross, red=static
color slColor = not i_useRaisingSL ? color.red : trailActive ? color.yellow : color.orange
plot(inPosition ? current_sl : na, "Stop Loss", slColor, 2, plot.style_linebr)

// TP line
plot(inPosition and not na(current_tp) ? current_tp : na, "Take Profit", color.green, 1, plot.style_linebr)

// ─── Clouds ──────────────────────────────────────────────────────────────

pC2a = plot(i_showCloud2 ? ema5 : na, "EMA 5", color.new(color.teal, 70))
pC2b = plot(i_showCloud2 ? ema12 : na, "EMA 12", color.new(color.teal, 70))
fill(pC2a, pC2b, cloud2_bull ? color.new(color.teal, 85) : color.new(color.maroon, 85))

pC3a = plot(i_showCloud3 ? ema34 : na, "EMA 34", color.new(color.blue, 70))
pC3b = plot(i_showCloud3 ? ema50 : na, "EMA 50", color.new(color.blue, 70))
fill(pC3a, pC3b, cloud3_bull ? color.new(color.green, 85) : color.new(color.red, 85))

pC4a = plot(i_showCloud4 ? ema72 : na, "EMA 72", color.new(color.purple, 70))
pC4b = plot(i_showCloud4 ? ema89 : na, "EMA 89", color.new(color.purple, 70))
fill(pC4a, pC4b, cloud4_bull ? color.new(color.green, 90) : color.new(color.red, 90))

// ═══════════════════════════════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════

if i_showDash and barstate.islast
    var table dash = table.new(position.top_right, 2, 11, bgcolor=color.new(#1e222d, 10))

    table.cell(dash, 0, 0, "4P v3.5.1S", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, posDir, text_color=posDir == "LONG" ? color.lime : posDir == "SHORT" ? color.red : color.gray, text_size=size.small)

    table.cell(dash, 0, 1, "9-3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 1, str.tostring(stoch_9_3, "#.0"), text_color=stoch_9_3 < crossLow ? color.lime : stoch_9_3 > crossHigh ? color.red : color.white, text_size=size.tiny)

    table.cell(dash, 0, 2, "14-3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 2, str.tostring(stoch_14_3, "#.0"), text_color=stoch_14_3 < zoneLow ? color.lime : stoch_14_3 > zoneHigh ? color.red : color.white, text_size=size.tiny)

    table.cell(dash, 0, 3, "40-3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(stoch_40_3, "#.0"), text_color=stoch_40_3 < zoneLow ? color.lime : stoch_40_3 > zoneHigh ? color.red : color.white, text_size=size.tiny)

    table.cell(dash, 0, 4, "60-10", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 4, str.tostring(stoch_60_10, "#.0"), text_color=stoch_60_10 < zoneLow ? color.lime : stoch_60_10 > zoneHigh ? color.red : color.white, text_size=size.tiny)

    string allInZone = others_oversold ? "ALL < " + str.tostring(zoneLow, "#") : others_overbought ? "ALL > " + str.tostring(zoneHigh, "#") : "---"
    color zoneColor = others_oversold ? color.lime : others_overbought ? color.red : color.gray
    table.cell(dash, 0, 5, "Zone", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 5, allInZone, text_color=zoneColor, text_size=size.tiny)

    table.cell(dash, 0, 6, "Cloud3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 6, cloud3_bull ? "BULL" : "BEAR", text_color=cloud3_bull ? color.lime : color.red, text_size=size.tiny)

    table.cell(dash, 0, 7, "Cloud2", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 7, cloud2_bull ? "BULL" : "BEAR", text_color=cloud2_bull ? color.lime : color.red, text_size=size.tiny)

    // SL mode: TRAIL (active), WAIT (Cloud 3/4 not crossed yet), STATIC
    string slStr = not inPosition ? "---" : not i_useRaisingSL ? "STATIC" : trailActive ? "TRAIL" : "WAIT"
    color slDashColor = not inPosition ? color.gray : not i_useRaisingSL ? color.red : trailActive ? color.yellow : color.orange
    table.cell(dash, 0, 8, "SL", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 8, slStr, text_color=slDashColor, text_size=size.tiny)

    // Entries count + trade grade
    string entryStr = inPosition ? str.tostring(1 + add_count) + tradeGrade : "---"
    table.cell(dash, 0, 9, "Entries", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 9, entryStr, text_color=inPosition ? (tradeGrade == "A" ? color.white : tradeGrade == "B" ? #80ff80 : #40ff40) : color.gray, text_size=size.tiny)

    // 60-10 D line
    string dStr = str.tostring(stoch_60_10_d, "#.0")
    color dColor = stoch_60_10_d > 20 and stoch_60_10_d < 80 ? color.lime : color.orange
    table.cell(dash, 0, 10, "60 D", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 10, dStr, text_color=dColor, text_size=size.tiny)
