//@version=6
indicator("Trade Dashboard", overlay=true)

// ============================================================================
// DASHBOARD FRAMEWORK v3.0
// Purpose: Visual checklist for trade entry grading
// Build Order: Last (after core indicators complete)
// ============================================================================

// ============================================================================
// SECTION 1: INPUTS
// ============================================================================

i_showDash      = input.bool(true, "Show Dashboard", group="Display")
i_showPostEntry = input.bool(false, "Show Post-Entry Panel", group="Display")
i_dashPos       = input.string("Top Right", "Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group="Display")

i_crossWindow   = input.int(3, "Cross Detection Bars", minval=1, maxval=10, group="Momentum")

i_atrLen        = input.int(14, "ATR Length", group="Risk")
i_atrMult       = input.float(2.0, "Stop ATR Mult", group="Risk")

// ============================================================================
// SECTION 2: CORE CALCULATIONS
// ============================================================================

atr_val = ta.atr(i_atrLen)

// ============================================================================
// SECTION 3: GATE MODULE (BBWP)
// ============================================================================

// BBWP is a GATE - must pass for any trade
// Returns: "blue" | "red" | "other"

get_bbwp_state() =>
    // STUB - REPLACE WITH ACTUAL BBWP
    // When replacing:
    // - Use BBWP spectrum line color detection
    // - Blue = BBWP < input threshold (default 20)
    // - Red = BBWP > input threshold (default 80)
    // - Make thresholds inputs
    
    "blue"  // STUB

bbwp_state = get_bbwp_state()
bbwp_pass = bbwp_state == "blue" or bbwp_state == "red"

// ============================================================================
// SECTION 4: SCORED MODULES (4 CONDITIONS)
// ============================================================================

// --- MODULE 1: MOMENTUM (Stochastics Combined) ---
// CRITICAL STUB: Divergence detection not implemented
// Automation blocked until divergence logic added

get_momentum_state() =>
    // Stoch 55 (55, 1, 12)
    stoch55_k_raw = ta.stoch(close, high, low, 55)
    stoch55_k = ta.sma(stoch55_k_raw, 1)
    stoch55_d = ta.sma(stoch55_k, 12)
    
    // Stoch 9 (9, 1, 3)
    stoch9_k_raw = ta.stoch(close, high, low, 9)
    stoch9_k = ta.sma(stoch9_k_raw, 1)
    stoch9_d = ta.sma(stoch9_k, 3)
    
    // Zone detection (approaching or in zone)
    stoch55_in_oversold = stoch55_k < 25
    stoch55_in_overbought = stoch55_k > 75
    
    // Cross detection within window
    cross_up = false
    cross_down = false
    for i = 0 to i_crossWindow - 1
        if ta.crossover(stoch55_k[i], stoch55_d[i])
            cross_up := true
        if ta.crossunder(stoch55_k[i], stoch55_d[i])
            cross_down := true
    
    // Stoch 9 continuation
    stoch9_rising = stoch9_k > stoch9_k[1]
    stoch9_falling = stoch9_k < stoch9_k[1]
    
    // CRITICAL STUB: Divergence detection
    // Replace with actual pivot-based divergence logic:
    // Bull div: price LL + stoch HL, previous stoch was <20
    // Bear div: price HH + stoch LH, previous stoch was >80
    bull_div = false  // CRITICAL: Replace
    bear_div = false  // CRITICAL: Replace
    
    // Alignment
    bull_aligned = (stoch55_in_oversold or cross_up or bull_div) and stoch9_rising
    bear_aligned = (stoch55_in_overbought or cross_down or bear_div) and stoch9_falling
    
    bull_aligned ? 1 : bear_aligned ? -1 : 0

// --- MODULE 2: TDI ---

get_tdi_state() =>
    // STUB: Replace with TDI CW_Trades external reference or full calc
    rsi_val = ta.rsi(close, 13)
    rsi_signal = ta.sma(rsi_val, 8)
    
    rsi_val > rsi_signal ? 1 : rsi_val < rsi_signal ? -1 : 0

// --- MODULE 3: RIPSTER ---
// Checks 34/50 (trend) + 5/12 (entry confirmation)

get_ripster_state() =>
    // Trend cloud (34/50)
    ema34 = ta.ema(close, 34)
    ema50 = ta.ema(close, 50)
    
    // Entry cloud (5/12)
    ema5 = ta.ema(close, 5)
    ema12 = ta.ema(close, 12)
    
    // 34/50 state
    trend_bull = ema34 > ema50
    trend_bear = ema34 < ema50
    trend_rising = ema34 > ema34[1] and ema50 > ema50[1]
    trend_falling = ema34 < ema34[1] and ema50 < ema50[1]
    
    // 5/12 state (entry confirmation)
    entry_bull = ema5 > ema12
    entry_bear = ema5 < ema12
    
    // Price position
    price_above_trend = close > ema34 and close > ema50
    price_below_trend = close < ema34 and close < ema50
    
    // Combined: trend + entry + price position + direction
    bull_state = price_above_trend and trend_bull and trend_rising and entry_bull
    bear_state = price_below_trend and trend_bear and trend_falling and entry_bear
    
    bull_state ? 1 : bear_state ? -1 : 0

// --- MODULE 4: AVWAP ---
// CRITICAL STUB: Using session VWAP - NOT anchored VWAP
// Automation blocked until proper anchor logic added

get_avwap_state() =>
    // CRITICAL STUB - REPLACE WITH ANCHORED VWAP
    // Options for anchor:
    // 1. Swing detection (ta.pivotlow/pivothigh)
    // 2. Manual input timestamp
    // 3. Significant level detection
    
    // Placeholder: Session VWAP (NOT correct for strategy)
    vwap_val = ta.vwap(hlc3)
    
    close > vwap_val ? 1 : close < vwap_val ? -1 : 0

// ============================================================================
// SECTION 5: STATE COLLECTION
// ============================================================================

momentum_state = get_momentum_state()
tdi_state      = get_tdi_state()
ripster_state  = get_ripster_state()
avwap_state    = get_avwap_state()

// ============================================================================
// SECTION 6: DIRECTION & GRADE CALCULATION
// ============================================================================

// Count directional alignment
bull_count = (momentum_state == 1 ? 1 : 0) + 
             (tdi_state == 1 ? 1 : 0) + 
             (ripster_state == 1 ? 1 : 0) + 
             (avwap_state == 1 ? 1 : 0)

bear_count = (momentum_state == -1 ? 1 : 0) + 
             (tdi_state == -1 ? 1 : 0) + 
             (ripster_state == -1 ? 1 : 0) + 
             (avwap_state == -1 ? 1 : 0)

// Score
score = math.max(bull_count, bear_count)
is_bull = bull_count > bear_count

// Direction (requires 3/4 minimum)
direction = bull_count >= 3 ? "LONG" : bear_count >= 3 ? "SHORT" : "WAIT"

// Grade (only if BBWP gate passes AND score >= 3)
grade = not bbwp_pass ? "—" : 
        score == 4 ? "A" : 
        score >= 3 ? "B" : "—"

// Target
target_atr = switch grade
    "A" => 6
    "B" => 4
    => 0

target_text = grade != "—" ? str.tostring(target_atr) + " ATR" : "No Trade"

// Score display
score_text = str.tostring(score) + "/4"

// ============================================================================
// SECTION 7: POST-ENTRY MODULES
// ============================================================================

// --- Continuation ---
// Tracks if Stoch 55 momentum continues after entry

get_continuation_state() =>
    stoch55_k_raw = ta.stoch(close, high, low, 55)
    stoch55_k = ta.sma(stoch55_k_raw, 1)
    
    // 2-bar trend
    rising = stoch55_k > stoch55_k[1] and stoch55_k[1] > stoch55_k[2]
    falling = stoch55_k < stoch55_k[1] and stoch55_k[1] < stoch55_k[2]
    
    rising ? 1 : falling ? -1 : 0

// --- ATR State ---

get_atr_state() =>
    atr_rising = atr_val > atr_val[1] and atr_val[1] > atr_val[2]
    atr_falling = atr_val < atr_val[1] and atr_val[1] < atr_val[2]
    
    atr_rising ? 1 : atr_falling ? -1 : 0

// --- 5m Trailing Stop ---

get_5m_trail_state() =>
    // STUB: Replace with HTF trailing logic
    // htf_close = request.security(syminfo.tickerid, "5", close)
    // Implement trailing stop on 5m timeframe
    
    1  // STUB: Active

continuation_state = get_continuation_state()
atr_state = get_atr_state()
trail_state = get_5m_trail_state()

// ============================================================================
// SECTION 8: DISPLAY FORMATTING
// ============================================================================

color_a     = color.green
color_b     = color.lime
color_none  = color.gray
color_bull  = color.green
color_bear  = color.red
color_neut  = color.gray

grade_color = switch grade
    "A" => color_a
    "B" => color_b
    => color_none

dir_color = direction == "LONG" ? color_bull : direction == "SHORT" ? color_bear : color_neut

// State displays
bbwp_display = bbwp_state == "blue" ? "Blue ✓" : bbwp_state == "red" ? "Red ✓" : "— ✗"
bbwp_color   = bbwp_pass ? color.blue : color_neut

momentum_display = momentum_state == 1 ? "▲" : momentum_state == -1 ? "▼" : "—"
momentum_color   = momentum_state == 1 ? color_bull : momentum_state == -1 ? color_bear : color_neut

tdi_display = tdi_state == 1 ? "▲" : tdi_state == -1 ? "▼" : "—"
tdi_color   = tdi_state == 1 ? color_bull : tdi_state == -1 ? color_bear : color_neut

ripster_display = ripster_state == 1 ? "▲" : ripster_state == -1 ? "▼" : "—"
ripster_color   = ripster_state == 1 ? color_bull : ripster_state == -1 ? color_bear : color_neut

avwap_display = avwap_state == 1 ? "Above" : avwap_state == -1 ? "Below" : "—"
avwap_color   = avwap_state == 1 ? color_bull : avwap_state == -1 ? color_bear : color_neut

// ATR displays
atr_display = str.tostring(atr_val, "#.######")
stop_display = str.tostring(atr_val * i_atrMult, "#.######")

// Post-entry displays
cont_display = continuation_state == 1 ? "Building" : continuation_state == -1 ? "Declining" : "Flat"
cont_color   = continuation_state == 1 ? color_bull : continuation_state == -1 ? color_bear : color_neut

atr_dir_display = atr_state == 1 ? "Rising" : atr_state == -1 ? "Falling" : "Flat"
atr_dir_color   = atr_state == 1 ? color_bull : atr_state == -1 ? color_bear : color_neut

trail_display = trail_state == 1 ? "Active" : "EXIT"
trail_color   = trail_state == 1 ? color_bull : color_bear

// ============================================================================
// SECTION 9: TABLE RENDERING
// ============================================================================

table_pos = switch i_dashPos
    "Top Right" => position.top_right
    "Top Left" => position.top_left
    "Bottom Right" => position.bottom_right
    "Bottom Left" => position.bottom_left
    => position.top_right

var table dash = table.new(table_pos, 3, 10, bgcolor=color.new(color.black, 30), border_width=1, border_color=color.gray)

if barstate.islast and i_showDash
    // Row 0: Grade + Score + Direction
    table.cell(dash, 0, 0, grade, text_color=grade_color, text_size=size.large, bgcolor=color.new(color.black, 50))
    table.cell(dash, 1, 0, score_text, text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 50))
    table.cell(dash, 2, 0, direction, text_color=dir_color, text_size=size.normal, bgcolor=color.new(color.black, 50))
    
    // Row 1: Target
    table.cell(dash, 0, 1, "Target", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, target_text, text_color=color.yellow, text_size=size.small)
    table.cell(dash, 2, 1, "", text_size=size.small)
    
    // Row 2: BBWP (Gate)
    table.cell(dash, 0, 2, "BBWP", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 1, 2, bbwp_display, text_color=bbwp_color, text_size=size.small, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 2, 2, "GATE", text_color=color.gray, text_size=size.tiny, bgcolor=color.new(color.gray, 70))
    
    // Row 3: Momentum
    table.cell(dash, 0, 3, "Momentum", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, momentum_display, text_color=momentum_color, text_size=size.small)
    table.cell(dash, 2, 3, "", text_size=size.small)
    
    // Row 4: TDI
    table.cell(dash, 0, 4, "TDI", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, tdi_display, text_color=tdi_color, text_size=size.small)
    table.cell(dash, 2, 4, "", text_size=size.small)
    
    // Row 5: Ripster
    table.cell(dash, 0, 5, "Ripster", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, ripster_display, text_color=ripster_color, text_size=size.small)
    table.cell(dash, 2, 5, "", text_size=size.small)
    
    // Row 6: AVWAP
    table.cell(dash, 0, 6, "AVWAP", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 6, avwap_display, text_color=avwap_color, text_size=size.small)
    table.cell(dash, 2, 6, "", text_size=size.small)
    
    // Row 7: Separator
    table.cell(dash, 0, 7, "ATR", text_color=color.gray, text_size=size.small, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 1, 7, atr_display, text_color=color.gray, text_size=size.small, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 2, 7, "", bgcolor=color.new(color.gray, 70))
    
    // Row 8: Stop
    table.cell(dash, 0, 8, "Stop", text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 8, stop_display, text_color=color.orange, text_size=size.small)
    table.cell(dash, 2, 8, "", text_size=size.small)

// ============================================================================
// SECTION 10: POST-ENTRY PANEL
// ============================================================================

var table post_dash = table.new(position.middle_right, 2, 4, bgcolor=color.new(color.black, 30), border_width=1, border_color=color.gray)

if barstate.islast and i_showPostEntry
    table.cell(post_dash, 0, 0, "POST", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 50))
    table.cell(post_dash, 1, 0, "", bgcolor=color.new(color.gray, 50))
    
    table.cell(post_dash, 0, 1, "Continuation", text_color=color.white, text_size=size.small)
    table.cell(post_dash, 1, 1, cont_display, text_color=cont_color, text_size=size.small)
    
    table.cell(post_dash, 0, 2, "ATR", text_color=color.white, text_size=size.small)
    table.cell(post_dash, 1, 2, atr_dir_display, text_color=atr_dir_color, text_size=size.small)
    
    table.cell(post_dash, 0, 3, "5m Trail", text_color=color.white, text_size=size.small)
    table.cell(post_dash, 1, 3, trail_display, text_color=trail_color, text_size=size.small)

// ============================================================================
// SECTION 11: ALERTS
// ============================================================================

alertcondition(grade == "A" and direction == "LONG", "A-Grade Long", "A-Grade LONG")
alertcondition(grade == "A" and direction == "SHORT", "A-Grade Short", "A-Grade SHORT")
alertcondition(grade == "B" and direction == "LONG", "B-Grade Long", "B-Grade LONG")
alertcondition(grade == "B" and direction == "SHORT", "B-Grade Short", "B-Grade SHORT")
alertcondition(trail_state == -1, "Trail Exit", "5m Trail Triggered - EXIT")
alertcondition(continuation_state == -1 and direction != "WAIT", "Continuation Fail", "Momentum Declining")
