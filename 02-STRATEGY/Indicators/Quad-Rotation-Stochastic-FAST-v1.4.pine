// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © Quad Rotation Stochastic FAST v1.4
// Methodology: John Kurisko HPS - Fast Variant
// Role: Momentum Rotation Detection (Pillar 4 of Four Pillars)
// Enhancements: Divergence detection (9-3 or 40-4 selectable), price chart visuals, info table
// Philosophy: Direction from OUTSIDE (AVWAP/Ripster), stochastics PRE-ANNOUNCE potential

//@version=6
indicator("Quad Rotation Stochastic FAST v1.4", shorttitle="QRS-FAST", overlay=false)

// ============================================================================
// INPUTS
// ============================================================================

// === ZONE SETTINGS ===
i_9_3_oversold = input.int(20, "9-3 Oversold", minval=10, maxval=30, group="Zones",
    tooltip="Strict oversold zone")
i_9_3_overbought = input.int(80, "9-3 Overbought", minval=70, maxval=90, group="Zones",
    tooltip="Strict overbought zone")
i_9_3_near_oversold = input.int(30, "9-3 Near Oversold", minval=20, maxval=40, group="Zones",
    tooltip="Near zone for lower confidence signals")
i_9_3_near_overbought = input.int(70, "9-3 Near Overbought", minval=60, maxval=80, group="Zones",
    tooltip="Near zone for lower confidence signals")

// === TIMING SETTINGS ===
i_zone_memory = input.int(3, "Zone Memory Bars", minval=1, maxval=10, group="Timing",
    tooltip="Bars to remember recent zone visit")
i_signal_cooldown = input.int(5, "Signal Cooldown Bars", minval=0, maxval=20, group="Timing",
    tooltip="Minimum bars between signals (0 = off)")

// === DIVERGENCE SETTINGS ===
i_div_enabled = input.bool(true, "Enable Divergence Detection", group="Divergence")
i_div_source = input.string("40-4", "Divergence Source", options=["9-3", "40-4"],
    group="Divergence", tooltip="40-4 (recommended) pre-announces direction per HPS methodology. 9-3 is faster but noisier.")
i_div_price_threshold = input.float(0.1, "Price Threshold %", minval=0.0, maxval=1.0, step=0.05,
    group="Divergence", tooltip="Tolerance for equal high/low")
i_div_lookback = input.int(15, "Divergence Lookback", minval=5, maxval=30,
    group="Divergence", tooltip="Max bars between Stage 1 and confirmation")
i_div_confirmation_window = input.int(2, "Confirmation Window", minval=1, maxval=5,
    group="Divergence", tooltip="Bars between price condition and turn confirmation")

// === EXIT ZONE SETTINGS ===
i_exit_warning = input.int(70, "Exit Warning Level", minval=60, maxval=80, group="Exit",
    tooltip="9-3 level to warn approaching exit zone")
i_exit_signal = input.int(80, "Exit Signal Level", minval=70, maxval=90, group="Exit",
    tooltip="9-3 level for take profit zone")

// === DISPLAY ===
i_show_9_3 = input.bool(true, "Show 9-3", group="Display")
i_show_14_3 = input.bool(false, "Show 14-3", group="Display")
i_show_40_4 = input.bool(false, "Show 40-4", group="Display")
i_show_60_10 = input.bool(false, "Show 60-10", group="Display")
i_show_info_table = input.bool(true, "Show Info Table", group="Display")
i_table_position = input.string("top_right", "Table Position",
    options=["top_right", "top_left", "bottom_right", "bottom_left"], group="Display")
i_show_div_lines = input.bool(true, "Show Divergence Lines", group="Display")
i_color_signal_candles = input.bool(true, "Color Signal Candles", group="Display",
    tooltip="Colors price candles orange on signal bars")
i_signal_candle_color = input.color(color.orange, "Signal Candle Color", group="Display")
i_show_price_triangles = input.bool(true, "Show Triangles on Price Chart", group="Display",
    tooltip="Shows buy/sell triangles directly on price candles")

// ============================================================================
// CONSTANTS
// ============================================================================

int WARMUP_BARS = 80  // 60-10 needs ~80 bars to initialize

// ============================================================================
// COMPONENT 1: STOCHASTIC CALCULATIONS
// ============================================================================

// FAST STOCHASTIC - Single smoothing (9-3, 14-3, 40-4)
stoch_fast(int k_len, int smooth_k) =>
    float lowest_low = ta.lowest(low, k_len)
    float highest_high = ta.highest(high, k_len)
    float range_val = highest_high - lowest_low
    float k_raw = range_val == 0 ? 50.0 : 100.0 * (close - lowest_low) / range_val
    float k = ta.sma(k_raw, smooth_k)
    k

// FULL STOCHASTIC - Double smoothing (60-10)
stoch_full(int k_len, int smooth_k) =>
    float lowest_low = ta.lowest(low, k_len)
    float highest_high = ta.highest(high, k_len)
    float range_val = highest_high - lowest_low
    float k_raw = range_val == 0 ? 50.0 : 100.0 * (close - lowest_low) / range_val
    float k_smooth1 = ta.sma(k_raw, smooth_k)
    float k_full = ta.sma(k_smooth1, smooth_k)
    k_full

// Calculate all 4 stochastics
float stoch_9_3 = stoch_fast(9, 3)
float stoch_14_3 = stoch_fast(14, 3)
float stoch_40_4 = stoch_fast(40, 4)
float stoch_60_10 = stoch_full(60, 10)

// Warmup check
bool is_warmed_up = bar_index >= WARMUP_BARS

// ============================================================================
// COMPONENT 2: ZONE DETECTION
// ============================================================================

// Zone memory - was recently in extreme zone
bool was_oversold = ta.lowest(stoch_9_3, i_zone_memory) < i_9_3_oversold
bool was_overbought = ta.highest(stoch_9_3, i_zone_memory) > i_9_3_overbought

// Near zones (lower confidence)
bool was_near_oversold = ta.lowest(stoch_9_3, i_zone_memory) < i_9_3_near_oversold
bool was_near_overbought = ta.highest(stoch_9_3, i_zone_memory) > i_9_3_near_overbought

// ============================================================================
// COMPONENT 3: ROTATION DETECTION
// ============================================================================

// 9-3 ROTATION (Primary) - Requires 2-bar momentum
bool stoch_9_3_rotating_up = stoch_9_3 > stoch_9_3[1] and stoch_9_3[1] > stoch_9_3[2]
bool stoch_9_3_rotating_down = stoch_9_3 < stoch_9_3[1] and stoch_9_3[1] < stoch_9_3[2]

// 14-3 CONFIRMATION - Single bar direction
bool stoch_14_3_up = stoch_14_3 > stoch_14_3[1]
bool stoch_14_3_down = stoch_14_3 < stoch_14_3[1]

// 40-4 DIRECTION - Context output
bool stoch_40_4_up = stoch_40_4 > stoch_40_4[1]
bool stoch_40_4_down = stoch_40_4 < stoch_40_4[1]
bool stoch_40_4_bullish = stoch_40_4 > 50
bool stoch_40_4_bearish = stoch_40_4 < 50

// 60-10 DIRECTION - Context output (channel)
bool stoch_60_10_up = stoch_60_10 > stoch_60_10[1]
bool stoch_60_10_down = stoch_60_10 < stoch_60_10[1]
bool stoch_60_10_flat = stoch_60_10 == stoch_60_10[1]  // FIX: Handle flat case
bool stoch_60_10_bullish = stoch_60_10 > 50
bool stoch_60_10_bearish = stoch_60_10 < 50

// FULL ROTATION - All 4 stochastics moving same direction
bool all_rotating_up = stoch_9_3_rotating_up and stoch_14_3_up and stoch_40_4_up and stoch_60_10_up
bool all_rotating_down = stoch_9_3_rotating_down and stoch_14_3_down and stoch_40_4_down and stoch_60_10_down

// ============================================================================
// COMPONENT 4: DIVERGENCE DETECTION (Source selectable: 9-3 or 40-4)
// ============================================================================

// Select divergence stochastic based on user choice
// 40-4 (default): Aligns with HPS methodology - slower stochastics pre-announce direction
// 9-3: Faster but noisier, catches more setups
float div_stoch = i_div_source == "40-4" ? stoch_40_4 : stoch_9_3
float div_stoch_prev = i_div_source == "40-4" ? stoch_40_4[1] : stoch_9_3[1]

// Zone thresholds for divergence (same 20/80 for both)
int div_oversold = 20
int div_overbought = 80
int div_hysteresis = 5

// Divergence state variables
var int bull_div_state = 0  // 0=waiting, 1=in_oversold, 2=bounced
var float bull_div_stage1_price = na
var float bull_div_stage1_stoch = na
var int bull_div_stage1_bar = na
var int bull_div_stage2_bar = na

var int bear_div_state = 0
var float bear_div_stage1_price = na
var float bear_div_stage1_stoch = na
var int bear_div_stage1_bar = na
var int bear_div_stage2_bar = na

// Counters for persistence
var int bars_since_bull_div = 999
var int bars_since_bear_div = 999

// Multi-bar confirmation tracking
var int bull_bars_since_price_cond = 999
var float bull_confirmed_stage1_stoch = na
var int bear_bars_since_price_cond = 999
var float bear_confirmed_stage1_stoch = na

// BULLISH DIVERGENCE STATE MACHINE
bool bullish_divergence = false

if i_div_enabled and is_warmed_up
    if bull_div_state == 0 and div_stoch < div_oversold
        // State 0 -> 1: Enter oversold
        bull_div_state := 1
        bull_div_stage1_price := low
        bull_div_stage1_stoch := div_stoch
        bull_div_stage1_bar := bar_index
        bull_bars_since_price_cond := 999
        bull_confirmed_stage1_stoch := na

    else if bull_div_state == 1 and div_stoch < div_oversold
        // State 1: Track lowest price while in oversold
        if low < bull_div_stage1_price
            bull_div_stage1_price := low
            bull_div_stage1_stoch := div_stoch
            bull_div_stage1_bar := bar_index

    else if bull_div_state == 1 and div_stoch >= div_oversold + div_hysteresis
        // State 1 -> 2: Exit oversold
        bull_div_state := 2
        bull_div_stage2_bar := bar_index

    else if bull_div_state == 2
        if div_stoch < div_oversold
            // Reset: re-entered oversold
            bull_div_state := 1
            bull_div_stage1_price := low
            bull_div_stage1_stoch := div_stoch
            bull_div_stage1_bar := bar_index
            bull_bars_since_price_cond := 999
            bull_confirmed_stage1_stoch := na
        else if bar_index - bull_div_stage2_bar > i_div_lookback
            // Reset: lookback exceeded
            bull_div_state := 0
            bull_bars_since_price_cond := 999
            bull_confirmed_stage1_stoch := na
        else
            // Check divergence conditions
            float price_threshold_band = bull_div_stage1_price * (1 + i_div_price_threshold / 100)
            bool price_lower_or_equal = low <= price_threshold_band
            bool stoch_higher_low = div_stoch > bull_div_stage1_stoch
            bool stoch_turning_up = div_stoch > div_stoch_prev

            // Track price condition for multi-bar window
            if price_lower_or_equal and stoch_higher_low
                bull_bars_since_price_cond := 0
                bull_confirmed_stage1_stoch := bull_div_stage1_stoch
            else
                bull_bars_since_price_cond := math.min(bull_bars_since_price_cond + 1, 999)

            // Check with confirmation window
            bool recent_price_cond = bull_bars_since_price_cond <= i_div_confirmation_window
            bool stoch_still_higher = not na(bull_confirmed_stage1_stoch) and div_stoch > bull_confirmed_stage1_stoch

            if recent_price_cond and stoch_still_higher and stoch_turning_up
                bullish_divergence := true
                bull_div_state := 0
                bull_bars_since_price_cond := 999
                bull_confirmed_stage1_stoch := na

// Update bars since divergence
if bullish_divergence
    bars_since_bull_div := 0
else
    bars_since_bull_div := math.min(bars_since_bull_div + 1, 999)

// BEARISH DIVERGENCE STATE MACHINE
bool bearish_divergence = false

if i_div_enabled and is_warmed_up
    if bear_div_state == 0 and div_stoch > div_overbought
        // State 0 -> 1: Enter overbought
        bear_div_state := 1
        bear_div_stage1_price := high
        bear_div_stage1_stoch := div_stoch
        bear_div_stage1_bar := bar_index
        bear_bars_since_price_cond := 999
        bear_confirmed_stage1_stoch := na

    else if bear_div_state == 1 and div_stoch > div_overbought
        // State 1: Track highest price while in overbought
        if high > bear_div_stage1_price
            bear_div_stage1_price := high
            bear_div_stage1_stoch := div_stoch
            bear_div_stage1_bar := bar_index

    else if bear_div_state == 1 and div_stoch <= div_overbought - div_hysteresis
        // State 1 -> 2: Exit overbought
        bear_div_state := 2
        bear_div_stage2_bar := bar_index

    else if bear_div_state == 2
        if div_stoch > div_overbought
            // Reset: re-entered overbought
            bear_div_state := 1
            bear_div_stage1_price := high
            bear_div_stage1_stoch := div_stoch
            bear_div_stage1_bar := bar_index
            bear_bars_since_price_cond := 999
            bear_confirmed_stage1_stoch := na
        else if bar_index - bear_div_stage2_bar > i_div_lookback
            // Reset: lookback exceeded
            bear_div_state := 0
            bear_bars_since_price_cond := 999
            bear_confirmed_stage1_stoch := na
        else
            // Check divergence conditions
            float price_threshold_band = bear_div_stage1_price * (1 - i_div_price_threshold / 100)
            bool price_higher_or_equal = high >= price_threshold_band
            bool stoch_lower_high = div_stoch < bear_div_stage1_stoch
            bool stoch_turning_down = div_stoch < div_stoch_prev

            // Track price condition for multi-bar window
            if price_higher_or_equal and stoch_lower_high
                bear_bars_since_price_cond := 0
                bear_confirmed_stage1_stoch := bear_div_stage1_stoch
            else
                bear_bars_since_price_cond := math.min(bear_bars_since_price_cond + 1, 999)

            // Check with confirmation window
            bool recent_price_cond = bear_bars_since_price_cond <= i_div_confirmation_window
            bool stoch_still_lower = not na(bear_confirmed_stage1_stoch) and div_stoch < bear_confirmed_stage1_stoch

            if recent_price_cond and stoch_still_lower and stoch_turning_down
                bearish_divergence := true
                bear_div_state := 0
                bear_bars_since_price_cond := 999
                bear_confirmed_stage1_stoch := na

// Update bars since divergence
if bearish_divergence
    bars_since_bear_div := 0
else
    bars_since_bear_div := math.min(bars_since_bear_div + 1, 999)

// Divergence active (within persistence window)
bool bull_div_active = bars_since_bull_div <= 5
bool bear_div_active = bars_since_bear_div <= 5

// ============================================================================
// COMPONENT 5: SIGNAL GENERATION
// ============================================================================

// SIGNAL TIERS (by rotation quality, NOT trend filtered)

// TIER 1: FAST ROTATION - 9-3 turning from strict zone
bool fast_rotation_long = is_warmed_up and was_oversold and stoch_9_3_rotating_up
bool fast_rotation_short = is_warmed_up and was_overbought and stoch_9_3_rotating_down

// TIER 2: FAST CONFIRMED - 9-3 + 14-3 aligned
bool fast_confirmed_long = is_warmed_up and was_oversold and stoch_9_3_rotating_up and stoch_14_3_up
bool fast_confirmed_short = is_warmed_up and was_overbought and stoch_9_3_rotating_down and stoch_14_3_down

// TIER 3: FAST FULL - All 4 stochastics rotating
bool fast_full_long = is_warmed_up and was_oversold and all_rotating_up
bool fast_full_short = is_warmed_up and was_overbought and all_rotating_down

// NEAR ZONE VARIANTS (lower confidence)
bool fast_near_long = is_warmed_up and was_near_oversold and not was_oversold and stoch_9_3_rotating_up and stoch_14_3_up
bool fast_near_short = is_warmed_up and was_near_overbought and not was_overbought and stoch_9_3_rotating_down and stoch_14_3_down

// DIVERGENCE + ROTATION COMBO (highest quality fast signal)
bool div_rotation_long = bullish_divergence and stoch_9_3_rotating_up
bool div_rotation_short = bearish_divergence and stoch_9_3_rotating_down

// ============================================================================
// COOLDOWN LOGIC
// ============================================================================

var int bars_since_long_signal = 999
var int bars_since_short_signal = 999

// ============================================================================
// EDGE DETECTION WITH COOLDOWN
// ============================================================================

// Raw edge detection
bool fast_rotation_long_raw = fast_rotation_long and not fast_rotation_long[1]
bool fast_rotation_short_raw = fast_rotation_short and not fast_rotation_short[1]

bool fast_confirmed_long_raw = fast_confirmed_long and not fast_confirmed_long[1]
bool fast_confirmed_short_raw = fast_confirmed_short and not fast_confirmed_short[1]

bool fast_full_long_raw = fast_full_long and not fast_full_long[1]
bool fast_full_short_raw = fast_full_short and not fast_full_short[1]

bool fast_near_long_raw = fast_near_long and not fast_near_long[1]
bool fast_near_short_raw = fast_near_short and not fast_near_short[1]

bool div_rotation_long_raw = div_rotation_long and not div_rotation_long[1]
bool div_rotation_short_raw = div_rotation_short and not div_rotation_short[1]

// Apply cooldown
bool cooldown_allows_long = i_signal_cooldown == 0 or bars_since_long_signal > i_signal_cooldown
bool cooldown_allows_short = i_signal_cooldown == 0 or bars_since_short_signal > i_signal_cooldown

// Final triggers
bool fast_rotation_long_trigger = fast_rotation_long_raw and cooldown_allows_long
bool fast_rotation_short_trigger = fast_rotation_short_raw and cooldown_allows_short

bool fast_confirmed_long_trigger = fast_confirmed_long_raw and cooldown_allows_long
bool fast_confirmed_short_trigger = fast_confirmed_short_raw and cooldown_allows_short

bool fast_full_long_trigger = fast_full_long_raw and cooldown_allows_long
bool fast_full_short_trigger = fast_full_short_raw and cooldown_allows_short

bool fast_near_long_trigger = fast_near_long_raw and cooldown_allows_long
bool fast_near_short_trigger = fast_near_short_raw and cooldown_allows_short

bool div_rotation_long_trigger = div_rotation_long_raw and cooldown_allows_long
bool div_rotation_short_trigger = div_rotation_short_raw and cooldown_allows_short

// Update cooldown counters
if fast_rotation_long_trigger or fast_confirmed_long_trigger or fast_full_long_trigger or div_rotation_long_trigger
    bars_since_long_signal := 0
else
    bars_since_long_signal := math.min(bars_since_long_signal + 1, 999)

if fast_rotation_short_trigger or fast_confirmed_short_trigger or fast_full_short_trigger or div_rotation_short_trigger
    bars_since_short_signal := 0
else
    bars_since_short_signal := math.min(bars_since_short_signal + 1, 999)

// ============================================================================
// COMPONENT 6: EXIT ZONES
// ============================================================================

bool exit_warning_long = stoch_9_3 > i_exit_warning and stoch_9_3 <= i_exit_signal
bool exit_zone_long = stoch_9_3 > i_exit_signal

bool exit_warning_short = stoch_9_3 < (100 - i_exit_warning) and stoch_9_3 >= (100 - i_exit_signal)
bool exit_zone_short = stoch_9_3 < (100 - i_exit_signal)

bool exit_warning_long_trigger = exit_warning_long and not exit_warning_long[1]
bool exit_zone_long_trigger = exit_zone_long and not exit_zone_long[1]
bool exit_warning_short_trigger = exit_warning_short and not exit_warning_short[1]
bool exit_zone_short_trigger = exit_zone_short and not exit_zone_short[1]

// ============================================================================
// PLOTTING - VISIBLE
// ============================================================================

plot(i_show_9_3 ? stoch_9_3 : na, "9-3", color=color.orange, linewidth=2)
plot(i_show_14_3 ? stoch_14_3 : na, "14-3", color=color.yellow, linewidth=1)
plot(i_show_40_4 ? stoch_40_4 : na, "40-4", color=color.blue, linewidth=1)
plot(i_show_60_10 ? stoch_60_10 : na, "60-10", color=color.purple, linewidth=1)

// Reference lines
hline(80, "Overbought", color=color.red, linestyle=hline.style_dashed)
hline(70, "Near OB", color=color.orange, linestyle=hline.style_dotted)
hline(50, "Midline", color=color.gray, linestyle=hline.style_solid)
hline(30, "Near OS", color=color.teal, linestyle=hline.style_dotted)
hline(20, "Oversold", color=color.green, linestyle=hline.style_dashed)

// Warmup indicator
bgcolor(not is_warmed_up ? color.new(color.gray, 95) : na)

// ============================================================================
// SIGNAL CANDLE COLORING
// ============================================================================

bool is_signal_bar = bullish_divergence or bearish_divergence or
                     fast_full_long_trigger or fast_full_short_trigger or
                     div_rotation_long_trigger or div_rotation_short_trigger

barcolor(i_color_signal_candles and is_signal_bar ? i_signal_candle_color : na)

// ============================================================================
// PRICE CHART TRIANGLES (force_overlay)
// ============================================================================

// Divergence signals on price chart
plotshape(i_show_price_triangles and bullish_divergence, "Price Bull Div",
    shape.triangleup, location.belowbar, color=color.green, size=size.small,
    text="DIV", textcolor=color.green, force_overlay=true)
plotshape(i_show_price_triangles and bearish_divergence, "Price Bear Div",
    shape.triangledown, location.abovebar, color=color.red, size=size.small,
    text="DIV", textcolor=color.red, force_overlay=true)

// FULL rotation signals on price chart
plotshape(i_show_price_triangles and fast_full_long_trigger, "Price Full Long",
    shape.triangleup, location.belowbar, color=color.lime, size=size.normal,
    text="FULL", textcolor=color.lime, force_overlay=true)
plotshape(i_show_price_triangles and fast_full_short_trigger, "Price Full Short",
    shape.triangledown, location.abovebar, color=color.fuchsia, size=size.normal,
    text="FULL", textcolor=color.fuchsia, force_overlay=true)

// Confirmed signals on price (smaller)
plotshape(i_show_price_triangles and fast_confirmed_long_trigger and not fast_full_long_trigger, "Price Conf Long",
    shape.triangleup, location.belowbar, color=color.teal, size=size.tiny,
    text="CONF", textcolor=color.teal, force_overlay=true)
plotshape(i_show_price_triangles and fast_confirmed_short_trigger and not fast_full_short_trigger, "Price Conf Short",
    shape.triangledown, location.abovebar, color=color.maroon, size=size.tiny,
    text="CONF", textcolor=color.maroon, force_overlay=true)

// ============================================================================
// DIVERGENCE LINES
// ============================================================================

var line bull_div_line = na
var line bear_div_line = na
var int bull_line_bar1 = na
var float bull_line_stoch1 = na
var int bear_line_bar1 = na
var float bear_line_stoch1 = na

// Track stage 1 for line drawing (using selected divergence stochastic)
if bull_div_state == 1 and bull_div_state[1] == 0
    bull_line_bar1 := bar_index
    bull_line_stoch1 := div_stoch

if bear_div_state == 1 and bear_div_state[1] == 0
    bear_line_bar1 := bar_index
    bear_line_stoch1 := div_stoch

// Update if new extreme
if bull_div_state == 1 and low < nz(bull_div_stage1_price, high)
    bull_line_bar1 := bar_index
    bull_line_stoch1 := div_stoch

if bear_div_state == 1 and high > nz(bear_div_stage1_price, low)
    bear_line_bar1 := bar_index
    bear_line_stoch1 := div_stoch

// Draw lines when divergence fires (on the divergence stochastic)
if bullish_divergence and i_show_div_lines
    if not na(bull_div_line)
        line.delete(bull_div_line)
    if not na(bull_line_bar1) and not na(bull_line_stoch1)
        bull_div_line := line.new(bull_line_bar1, bull_line_stoch1, bar_index, div_stoch,
            color=color.green, width=2, style=line.style_solid)
        label.new(bar_index, div_stoch - 5, "BULL DIV (" + i_div_source + ")",
            color=color.new(color.green, 70), textcolor=color.white,
            style=label.style_label_up, size=size.small)

if bearish_divergence and i_show_div_lines
    if not na(bear_div_line)
        line.delete(bear_div_line)
    if not na(bear_line_bar1) and not na(bear_line_stoch1)
        bear_div_line := line.new(bear_line_bar1, bear_line_stoch1, bar_index, div_stoch,
            color=color.red, width=2, style=line.style_solid)
        label.new(bar_index, div_stoch + 5, "BEAR DIV (" + i_div_source + ")",
            color=color.new(color.red, 70), textcolor=color.white,
            style=label.style_label_down, size=size.small)

// ============================================================================
// INFO TABLE
// ============================================================================

var table info_table = na

if i_show_info_table
    if na(info_table)
        table_pos = switch i_table_position
            "top_right" => position.top_right
            "top_left" => position.top_left
            "bottom_right" => position.bottom_right
            "bottom_left" => position.bottom_left
            => position.top_right
        info_table := table.new(table_pos, 2, 12, bgcolor=color.new(color.black, 80), border_width=1)

    // Header
    table.cell(info_table, 0, 0, "QRS-FAST", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 0, "VALUE", text_color=color.white, text_size=size.small)

    // Zone Status
    zone_text = was_oversold ? "OVERSOLD" : was_overbought ? "OVERBOUGHT" :
                was_near_oversold ? "Near OS" : was_near_overbought ? "Near OB" : "Neutral"
    zone_color = was_oversold ? color.green : was_overbought ? color.red :
                 was_near_oversold ? color.teal : was_near_overbought ? color.orange : color.gray
    table.cell(info_table, 0, 1, "Zone", text_color=color.white, text_size=size.tiny)
    table.cell(info_table, 1, 1, zone_text, text_color=zone_color, text_size=size.tiny)

    // Rotation Status
    rot_text = all_rotating_up ? "ALL UP" : all_rotating_down ? "ALL DOWN" :
               stoch_9_3_rotating_up ? "9-3 UP" : stoch_9_3_rotating_down ? "9-3 DOWN" : "None"
    rot_color = all_rotating_up ? color.lime : all_rotating_down ? color.fuchsia :
                stoch_9_3_rotating_up ? color.green : stoch_9_3_rotating_down ? color.red : color.gray
    table.cell(info_table, 0, 2, "Rotation", text_color=color.white, text_size=size.tiny)
    table.cell(info_table, 1, 2, rot_text, text_color=rot_color, text_size=size.tiny)

    // Divergence State (shows source)
    div_state_text = bull_div_state == 1 ? "Bull S1" : bull_div_state == 2 ? "Bull S2" :
                     bear_div_state == 1 ? "Bear S1" : bear_div_state == 2 ? "Bear S2" : "Waiting"
    div_state_color = bull_div_state > 0 ? color.green : bear_div_state > 0 ? color.red : color.gray
    table.cell(info_table, 0, 3, "Div (" + i_div_source + ")", text_color=color.white, text_size=size.tiny)
    table.cell(info_table, 1, 3, div_state_text, text_color=div_state_color, text_size=size.tiny)

    // Divergence Active
    div_text = bull_div_active ? "BULL (" + str.tostring(bars_since_bull_div) + ")" :
               bear_div_active ? "BEAR (" + str.tostring(bars_since_bear_div) + ")" : "None"
    div_color = bull_div_active ? color.green : bear_div_active ? color.red : color.gray
    table.cell(info_table, 0, 4, "Div Active", text_color=color.white, text_size=size.tiny)
    table.cell(info_table, 1, 4, div_text, text_color=div_color, text_size=size.tiny)

    // 40-4 Context
    mid_text = stoch_40_4_bullish ? (stoch_40_4_up ? "Bull Rising" : "Bull Falling") :
               (stoch_40_4_down ? "Bear Falling" : "Bear Rising")
    mid_color = stoch_40_4_bullish ? color.green : color.red
    table.cell(info_table, 0, 5, "40-4 Mid", text_color=color.white, text_size=size.tiny)
    table.cell(info_table, 1, 5, mid_text, text_color=mid_color, text_size=size.tiny)

    // 60-10 Channel
    channel_text = stoch_60_10_bullish ? (stoch_60_10_up ? "Bull Rising" : stoch_60_10_flat ? "Bull Flat" : "Bull Falling") :
                   (stoch_60_10_down ? "Bear Falling" : stoch_60_10_flat ? "Bear Flat" : "Bear Rising")
    channel_color = stoch_60_10_bullish ? color.green : color.red
    table.cell(info_table, 0, 6, "60-10 Ch", text_color=color.white, text_size=size.tiny)
    table.cell(info_table, 1, 6, channel_text, text_color=channel_color, text_size=size.tiny)

    // Cooldown
    cd_text = "L:" + str.tostring(bars_since_long_signal) + " S:" + str.tostring(bars_since_short_signal)
    table.cell(info_table, 0, 7, "Cooldown", text_color=color.white, text_size=size.tiny)
    table.cell(info_table, 1, 7, cd_text, text_color=color.gray, text_size=size.tiny)

    // Separator
    table.cell(info_table, 0, 8, "─────", text_color=color.gray, text_size=size.tiny)
    table.cell(info_table, 1, 8, "─────", text_color=color.gray, text_size=size.tiny)

    // Stochastic values
    stoch_color(float val) =>
        val > 60 ? color.green : val < 40 ? color.red : color.gray

    table.cell(info_table, 0, 9, "9-3", text_color=color.orange, text_size=size.tiny)
    table.cell(info_table, 1, 9, str.tostring(stoch_9_3, "#.#"), text_color=stoch_color(stoch_9_3), text_size=size.tiny)

    table.cell(info_table, 0, 10, "14-3", text_color=color.yellow, text_size=size.tiny)
    table.cell(info_table, 1, 10, str.tostring(stoch_14_3, "#.#"), text_color=stoch_color(stoch_14_3), text_size=size.tiny)

    table.cell(info_table, 0, 11, "40-4", text_color=color.blue, text_size=size.tiny)
    table.cell(info_table, 1, 11, str.tostring(stoch_40_4, "#.#"), text_color=stoch_color(stoch_40_4), text_size=size.tiny)

// ============================================================================
// PLOTTING - HIDDEN (for JSON alerts / integration)
// ============================================================================

plot(stoch_9_3, "stoch_9_3", display=display.none)
plot(stoch_14_3, "stoch_14_3", display=display.none)
plot(stoch_40_4, "stoch_40_4", display=display.none)
plot(stoch_60_10, "stoch_60_10", display=display.none)

// FIX: Improved channel_numeric with flat case handling
// -3=bearish_flat, -2=bearish_falling, -1=bearish_rising, 1=bullish_falling, 2=bullish_flat, 3=bullish_rising
channel_numeric_val = stoch_60_10_bullish ?
    (stoch_60_10_up ? 3 : stoch_60_10_flat ? 2 : 1) :
    (stoch_60_10_down ? -2 : stoch_60_10_flat ? -3 : -1)
plot(channel_numeric_val, "channel_numeric", display=display.none)

plot(stoch_40_4_bullish ? 1 : -1, "mid_numeric", display=display.none)
plot(was_oversold ? -2 : was_near_oversold ? -1 : was_overbought ? 2 : was_near_overbought ? 1 : 0, "zone_numeric", display=display.none)
plot(is_warmed_up ? 1 : 0, "is_warmed_up", display=display.none)
plot(bars_since_long_signal, "bars_since_long_signal", display=display.none)
plot(bars_since_short_signal, "bars_since_short_signal", display=display.none)
plot(bull_div_active ? 1 : bear_div_active ? -1 : 0, "div_active", display=display.none)
plot(bars_since_bull_div, "bars_since_bull_div", display=display.none)
plot(bars_since_bear_div, "bars_since_bear_div", display=display.none)
plot(i_div_source == "40-4" ? 1 : 0, "div_source_40_4", display=display.none)  // 1=40-4, 0=9-3

// ============================================================================
// PLOTTING - SIGNAL MARKERS (Indicator Pane)
// ============================================================================

// Divergence markers
plotshape(bullish_divergence, "Bull Div", shape.triangleup, location.bottom,
    color=color.green, size=size.small, text="DIV")
plotshape(bearish_divergence, "Bear Div", shape.triangledown, location.top,
    color=color.red, size=size.small, text="DIV")

// FULL signals (highest quality)
plotshape(fast_full_long_trigger, "FULL LONG", shape.labelup, location.bottom,
    color=color.lime, size=size.normal, text="FULL")
plotshape(fast_full_short_trigger, "FULL SHORT", shape.labeldown, location.top,
    color=color.fuchsia, size=size.normal, text="FULL")

// CONFIRMED signals
plotshape(fast_confirmed_long_trigger and not fast_full_long_trigger, "CONF LONG", shape.triangleup, location.bottom,
    color=color.teal, size=size.small, text="CONF")
plotshape(fast_confirmed_short_trigger and not fast_full_short_trigger, "CONF SHORT", shape.triangledown, location.top,
    color=color.maroon, size=size.small, text="CONF")

// ROTATION signals (lowest tier from strict zone)
plotshape(fast_rotation_long_trigger and not fast_confirmed_long_trigger, "ROT LONG", shape.circle, location.bottom,
    color=color.teal, size=size.tiny)
plotshape(fast_rotation_short_trigger and not fast_confirmed_short_trigger, "ROT SHORT", shape.circle, location.top,
    color=color.maroon, size=size.tiny)

// NEAR zone signals
plotshape(fast_near_long_trigger, "NEAR LONG", shape.diamond, location.bottom,
    color=color.new(color.green, 50), size=size.tiny, text="N")
plotshape(fast_near_short_trigger, "NEAR SHORT", shape.diamond, location.top,
    color=color.new(color.red, 50), size=size.tiny, text="N")

// Exit markers
plotshape(exit_warning_long_trigger, "Exit Warn L", shape.xcross, location.top,
    color=color.orange, size=size.tiny)
plotshape(exit_zone_long_trigger, "Exit Zone L", shape.square, location.top,
    color=color.red, size=size.small, text="TP")
plotshape(exit_warning_short_trigger, "Exit Warn S", shape.xcross, location.bottom,
    color=color.orange, size=size.tiny)
plotshape(exit_zone_short_trigger, "Exit Zone S", shape.square, location.bottom,
    color=color.green, size=size.small, text="TP")

// Divergence stage markers
plotshape(bull_div_state == 1 and bull_div_state[1] == 0, "Bull Div S1", shape.circle, location.bottom,
    color=color.new(color.green, 50), size=size.tiny, text="D1")
plotshape(bull_div_state == 2 and bull_div_state[1] == 1, "Bull Div S2", shape.circle, location.bottom,
    color=color.new(color.lime, 50), size=size.tiny, text="D2")
plotshape(bear_div_state == 1 and bear_div_state[1] == 0, "Bear Div S1", shape.circle, location.top,
    color=color.new(color.red, 50), size=size.tiny, text="D1")
plotshape(bear_div_state == 2 and bear_div_state[1] == 1, "Bear Div S2", shape.circle, location.top,
    color=color.new(color.orange, 50), size=size.tiny, text="D2")

// ============================================================================
// ALERTS - DIVERGENCE
// ============================================================================

alertcondition(bullish_divergence, "Bullish Divergence", "Bullish divergence detected (source: user selected)")
alertcondition(bearish_divergence, "Bearish Divergence", "Bearish divergence detected (source: user selected)")
alertcondition(div_rotation_long_trigger, "DIV + ROTATION LONG", "Divergence with rotation - HIGH QUALITY")
alertcondition(div_rotation_short_trigger, "DIV + ROTATION SHORT", "Divergence with rotation - HIGH QUALITY")

// ============================================================================
// ALERTS - ENTRY SIGNALS (Tiered)
// ============================================================================

alertcondition(fast_full_long_trigger, "FAST FULL LONG", "All 4 stochastics rotating up from oversold")
alertcondition(fast_full_short_trigger, "FAST FULL SHORT", "All 4 stochastics rotating down from overbought")
alertcondition(fast_confirmed_long_trigger, "FAST CONFIRMED LONG", "9-3 + 14-3 rotating up from oversold")
alertcondition(fast_confirmed_short_trigger, "FAST CONFIRMED SHORT", "9-3 + 14-3 rotating down from overbought")
alertcondition(fast_rotation_long_trigger, "FAST ROTATION LONG", "9-3 rotating up from oversold")
alertcondition(fast_rotation_short_trigger, "FAST ROTATION SHORT", "9-3 rotating down from overbought")
alertcondition(fast_near_long_trigger, "FAST NEAR LONG", "9-3 + 14-3 rotating from near-oversold")
alertcondition(fast_near_short_trigger, "FAST NEAR SHORT", "9-3 + 14-3 rotating from near-overbought")

// ============================================================================
// ALERTS - EXIT SIGNALS
// ============================================================================

alertcondition(exit_warning_long_trigger, "9-3 Exit Warning Long", "9-3 approaching overbought")
alertcondition(exit_zone_long_trigger, "9-3 Exit Zone Long", "9-3 in overbought zone")
alertcondition(exit_warning_short_trigger, "9-3 Exit Warning Short", "9-3 approaching oversold")
alertcondition(exit_zone_short_trigger, "9-3 Exit Zone Short", "9-3 in oversold zone")

// ============================================================================
// ALERTS - ANY SIGNAL
// ============================================================================

bool any_long_signal = fast_full_long_trigger or fast_confirmed_long_trigger or fast_rotation_long_trigger or fast_near_long_trigger or bullish_divergence
bool any_short_signal = fast_full_short_trigger or fast_confirmed_short_trigger or fast_rotation_short_trigger or fast_near_short_trigger or bearish_divergence

alertcondition(any_long_signal, "ANY FAST LONG", "Any long signal fired")
alertcondition(any_short_signal, "ANY FAST SHORT", "Any short signal fired")
