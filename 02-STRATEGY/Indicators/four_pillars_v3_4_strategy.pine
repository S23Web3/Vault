//@version=6
// Four Pillars v3.4.1 Strategy - Backtesting Version
// Identical logic to the v3.4 indicator, wrapped in strategy() for backtesting
// A/B/C trade grading, phased ATR position management, Cloud 2 hard close, ADD signals

strategy("Four Pillars v3.4.1 Strategy", shorttitle="4Pv3.4.1-S", overlay=true,
         initial_capital=10000, default_qty_type=strategy.percent_of_equity,
         default_qty_value=100, commission_type=strategy.commission.percent,
         commission_value=0.1, pyramiding=10, process_orders_on_close=true,
         max_labels_count=500)

// ═══════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════

grp1 = "═══ STOCHASTIC SETTINGS ═══"
i_crossLevel = input.int(20, "9-3 Cross Level", minval=10, maxval=40, group=grp1, tooltip="9-3 must cross this level (20 = cross 20/80)")
i_zoneLevel = input.int(30, "Others Zone Level", minval=20, maxval=40, group=grp1, tooltip="Other stochs must be below/above this")
i_allowBTrades = input.bool(true, "Allow B Trades (3/4 stochs)", group=grp1, tooltip="Enter on 3 of 4 stochastic alignment (labeled B)")
i_allowCTrades = input.bool(true, "Allow C Trades (2/4 + Cloud 3)", group=grp1, tooltip="9-3 + 14-3 aligned with Cloud 3 confirmation, same direction as last trade")

grp2 = "═══ RIPSTER EMAs ═══"
i_ema5 = input.int(5, "EMA 5 (Cloud 2 Short)", group=grp2)
i_ema12 = input.int(12, "EMA 12 (Cloud 2 Long)", group=grp2)
i_ema34 = input.int(34, "EMA 34 (Cloud 3 Short)", group=grp2)
i_ema50 = input.int(50, "EMA 50 (Cloud 3 Long)", group=grp2)
i_ema72 = input.int(72, "EMA 72 (Cloud 4 Short)", group=grp2)
i_ema89 = input.int(89, "EMA 89 (Cloud 4 Long)", group=grp2)

grp3 = "═══ POSITION MANAGEMENT ═══"
i_atrLen = input.int(14, "ATR Length", group=grp3)
i_slMult = input.float(2.0, "Initial SL ATR Mult", step=0.1, group=grp3)
i_tpMult = input.float(4.0, "Initial TP ATR Mult", step=0.1, group=grp3)
i_useTP = input.bool(true, "Use Take Profit", group=grp3, tooltip="When OFF, no TP is set — trades exit only via SL, Cloud 2 flip, or Phase 3 trail")
i_useAngleTrail = input.bool(false, "Angle Trail: Tight SL when Cloud 3 steep", group=grp3, tooltip="When Cloud 3 angle > threshold, SL tightens to 1 ATR above cloud top (long) or below cloud bottom (short)")
i_angleThreshold = input.float(15.0, "Angle Threshold (degrees)", minval=5.0, maxval=45.0, step=1.0, group=grp3, tooltip="Cloud 3 slope angle that triggers tight trail mode")

grp3b = "═══ ADD SIGNAL SETTINGS ═══"
i_addZoneShort = input.int(70, "Short ADD: 9-3 must enter zone above", minval=60, maxval=90, group=grp3b, tooltip="9-3 dips above this, then exits below = short ADD")
i_addZoneLong = input.int(30, "Long ADD: 9-3 must enter zone below", minval=10, maxval=40, group=grp3b, tooltip="9-3 dips below this, then exits above = long ADD")
i_addMidShort = input.float(52.0, "Short ADD: 40/60 must stay below", step=1.0, group=grp3b, tooltip="40-3 and 60-10 must stay below this (bearish bias intact)")
i_addMidLong = input.float(48.0, "Long ADD: 40/60 must stay above", step=1.0, group=grp3b, tooltip="40-3 and 60-10 must stay above this (bullish bias intact)")

grp4 = "═══ FILTERS ═══"
i_useRipster = input.bool(false, "Use Ripster Cloud Filter", group=grp4, tooltip="Require Cloud 3 alignment for entry")
i_use60D = input.bool(false, "Use 60-10 D Filter", group=grp4, tooltip="Require 60-10 D: >20 for long, <80 for short")

grp5 = "═══ VISUALS ═══"
i_showDash = input.bool(true, "Show Dashboard", group=grp5)
i_showCloud2 = input.bool(false, "Show Cloud 2 (5/12)", group=grp5)
i_showCloud3 = input.bool(false, "Show Cloud 3 (34/50)", group=grp5)
i_showCloud4 = input.bool(false, "Show Cloud 4 (72/89)", group=grp5)

// ═══════════════════════════════════════════════════════════════════════════
// STOCHASTIC CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════════

stoch_k_line(int k_len) =>
    float lowest = ta.lowest(low, k_len)
    float highest = ta.highest(high, k_len)
    highest - lowest == 0 ? 50.0 : 100.0 * (close - lowest) / (highest - lowest)

float stoch_9_3 = stoch_k_line(9)
float stoch_14_3 = stoch_k_line(14)
float stoch_40_3 = stoch_k_line(40)
float stoch_60_10 = stoch_k_line(60)
float stoch_60_10_d = ta.sma(stoch_60_10, 10)

// ═══════════════════════════════════════════════════════════════════════════
// RIPSTER CLOUDS (2, 3, 4)
// ═══════════════════════════════════════════════════════════════════════════

float ema5 = ta.ema(close, i_ema5)
float ema12 = ta.ema(close, i_ema12)
bool cloud2_bull = ema5 > ema12
bool cloud2_cross_bull = ta.crossover(ema5, ema12)
bool cloud2_cross_bear = ta.crossunder(ema5, ema12)

float ema34 = ta.ema(close, i_ema34)
float ema50 = ta.ema(close, i_ema50)
bool cloud3_bull = ema34 > ema50
bool cloud3_cross_bull = ta.crossover(ema34, ema50)
bool cloud3_cross_bear = ta.crossunder(ema34, ema50)
float cloud_top = math.max(ema34, ema50)
float cloud_bottom = math.min(ema34, ema50)
int price_pos = close > cloud_top ? 1 : close < cloud_bottom ? -1 : 0

float ema72 = ta.ema(close, i_ema72)
float ema89 = ta.ema(close, i_ema89)
bool cloud4_bull = ema72 > ema89

// Cloud 3 angle — measures slope of cloud midpoint normalized by ATR
float cloud3_mid = (ema34 + ema50) / 2.0
float _atr_norm = nz(ta.atr(i_atrLen), 1.0)
float cloud3_change = _atr_norm > 0 ? (cloud3_mid - nz(cloud3_mid[1], cloud3_mid)) / _atr_norm : 0.0
float cloud3_angle = math.atan(cloud3_change * 10.0) * (180.0 / math.pi)
bool angleSteepLong = cloud3_angle > i_angleThreshold
bool angleSteepShort = cloud3_angle < -i_angleThreshold

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY SIGNAL LOGIC
// ═══════════════════════════════════════════════════════════════════════════

float crossLow = i_crossLevel
float crossHigh = 100 - i_crossLevel
float zoneLow = i_zoneLevel
float zoneHigh = 100 - i_zoneLevel

bool cross_up = ta.crossover(stoch_9_3, crossLow)
bool cross_down = ta.crossunder(stoch_9_3, crossHigh)

// A trades: 4/4 alignment
// A trade: 60-10 must reach crossLow (20) / crossHigh (80) — stricter than zone level
bool others_oversold_now = stoch_14_3 < zoneLow and stoch_40_3 < zoneLow and stoch_60_10 < crossLow
bool others_oversold_1 = stoch_14_3[1] < zoneLow and stoch_40_3[1] < zoneLow and stoch_60_10[1] < crossLow
bool others_oversold_2 = stoch_14_3[2] < zoneLow and stoch_40_3[2] < zoneLow and stoch_60_10[2] < crossLow
bool others_oversold = others_oversold_now or others_oversold_1 or others_oversold_2

bool others_overbought_now = stoch_14_3 > zoneHigh and stoch_40_3 > zoneHigh and stoch_60_10 > crossHigh
bool others_overbought_1 = stoch_14_3[1] > zoneHigh and stoch_40_3[1] > zoneHigh and stoch_60_10[1] > crossHigh
bool others_overbought_2 = stoch_14_3[2] > zoneHigh and stoch_40_3[2] > zoneHigh and stoch_60_10[2] > crossHigh
bool others_overbought = others_overbought_now or others_overbought_1 or others_overbought_2

bool ripster_ok_long = not i_useRipster or cloud3_bull or price_pos >= 0
bool ripster_ok_short = not i_useRipster or not cloud3_bull or price_pos <= 0

bool d_ok_long = not i_use60D or stoch_60_10_d > 20
bool d_ok_short = not i_use60D or stoch_60_10_d < 80

bool long_signal = cross_up and others_oversold and ripster_ok_long and d_ok_long
bool short_signal = cross_down and others_overbought and ripster_ok_short and d_ok_short

// B trades: 3/4 alignment
int os_count_now = (stoch_14_3 < zoneLow ? 1 : 0) + (stoch_40_3 < zoneLow ? 1 : 0) + (stoch_60_10 < zoneLow ? 1 : 0)
int os_count_1 = (stoch_14_3[1] < zoneLow ? 1 : 0) + (stoch_40_3[1] < zoneLow ? 1 : 0) + (stoch_60_10[1] < zoneLow ? 1 : 0)
int os_count_2 = (stoch_14_3[2] < zoneLow ? 1 : 0) + (stoch_40_3[2] < zoneLow ? 1 : 0) + (stoch_60_10[2] < zoneLow ? 1 : 0)
bool b_oversold = os_count_now >= 2 or os_count_1 >= 2 or os_count_2 >= 2

int ob_count_now = (stoch_14_3 > zoneHigh ? 1 : 0) + (stoch_40_3 > zoneHigh ? 1 : 0) + (stoch_60_10 > zoneHigh ? 1 : 0)
int ob_count_1 = (stoch_14_3[1] > zoneHigh ? 1 : 0) + (stoch_40_3[1] > zoneHigh ? 1 : 0) + (stoch_60_10[1] > zoneHigh ? 1 : 0)
int ob_count_2 = (stoch_14_3[2] > zoneHigh ? 1 : 0) + (stoch_40_3[2] > zoneHigh ? 1 : 0) + (stoch_60_10[2] > zoneHigh ? 1 : 0)
bool b_overbought = ob_count_now >= 2 or ob_count_1 >= 2 or ob_count_2 >= 2

bool long_signal_b = i_allowBTrades and cross_up and not others_oversold and b_oversold and ripster_ok_long and d_ok_long
bool short_signal_b = i_allowBTrades and cross_down and not others_overbought and b_overbought and ripster_ok_short and d_ok_short

// C trades: 2/4 (fast pair) + Cloud 3 confirmation
bool c_14_oversold = stoch_14_3 < zoneLow or stoch_14_3[1] < zoneLow or stoch_14_3[2] < zoneLow
bool c_14_overbought = stoch_14_3 > zoneHigh or stoch_14_3[1] > zoneHigh or stoch_14_3[2] > zoneHigh
bool c_long_base = i_allowCTrades and cross_up and c_14_oversold and price_pos == 1 and not long_signal and not long_signal_b
bool c_short_base = i_allowCTrades and cross_down and c_14_overbought and price_pos == -1 and not short_signal and not short_signal_b

// ADD signals
bool add_short_trigger = ta.crossunder(stoch_9_3, i_addZoneShort) and stoch_40_3 < i_addMidShort and stoch_60_10 < i_addMidShort
bool add_long_trigger = ta.crossover(stoch_9_3, i_addZoneLong) and stoch_40_3 > i_addMidLong and stoch_60_10 > i_addMidLong

// ═══════════════════════════════════════════════════════════════════════════
// POSITION STATE
// ═══════════════════════════════════════════════════════════════════════════

float atr = ta.atr(i_atrLen)

var bool inPosition = false
var string posDir = "FLAT"
var float entryPrice = na
var float current_sl = na
var float current_tp = na
var int entryBar = na
var int sl_phase = 0
var float trail_extreme = na
var int add_count = 0
var bool phase1_done = false
var bool phase2_done = false
var string tradeGrade = ""
var string lastTradeDir = ""

bool exitCloud2 = false
bool exitSL = false
bool exitTP = false
bool didAdd = false
bool phaseChanged = false
string exitPosDir = ""

// ═══════════════════════════════════════════════════════════════════════════
// EXIT CHECKS
// ═══════════════════════════════════════════════════════════════════════════

if inPosition
    if posDir == "LONG" and cloud2_cross_bear
        exitCloud2 := true
    else if posDir == "SHORT" and cloud2_cross_bull
        exitCloud2 := true

    if not exitCloud2
        if posDir == "LONG" and low <= current_sl
            exitSL := true
        else if posDir == "SHORT" and high >= current_sl
            exitSL := true

    if not exitCloud2 and not exitSL and sl_phase != 3 and not na(current_tp)
        if posDir == "LONG" and high >= current_tp
            exitTP := true
        else if posDir == "SHORT" and low <= current_tp
            exitTP := true

    if exitCloud2 or exitSL or exitTP
        exitPosDir := posDir
        lastTradeDir := posDir
        inPosition := false
        posDir := "FLAT"
        entryPrice := na
        current_sl := na
        current_tp := na
        entryBar := na
        sl_phase := 0
        trail_extreme := na
        add_count := 0
        phase1_done := false
        phase2_done := false
        tradeGrade := ""

// ═══════════════════════════════════════════════════════════════════════════
// NEW ENTRIES / ADD
// ═══════════════════════════════════════════════════════════════════════════

if long_signal and not inPosition
    inPosition := true
    posDir := "LONG"
    entryPrice := close
    entryBar := bar_index
    current_sl := close - (i_slMult * atr)
    current_tp := i_useTP ? close + (i_tpMult * atr) : na
    sl_phase := 0
    trail_extreme := na
    add_count := 0
    phase1_done := false
    phase2_done := false
    tradeGrade := "A"

else if short_signal and not inPosition
    inPosition := true
    posDir := "SHORT"
    entryPrice := close
    entryBar := bar_index
    current_sl := close + (i_slMult * atr)
    current_tp := i_useTP ? close - (i_tpMult * atr) : na
    sl_phase := 0
    trail_extreme := na
    add_count := 0
    phase1_done := false
    phase2_done := false
    tradeGrade := "A"

else if long_signal_b and not inPosition
    inPosition := true
    posDir := "LONG"
    entryPrice := close
    entryBar := bar_index
    current_sl := close - (i_slMult * atr)
    current_tp := i_useTP ? close + (i_tpMult * atr) : na
    sl_phase := 0
    trail_extreme := na
    add_count := 0
    phase1_done := false
    phase2_done := false
    tradeGrade := "B"

else if short_signal_b and not inPosition
    inPosition := true
    posDir := "SHORT"
    entryPrice := close
    entryBar := bar_index
    current_sl := close + (i_slMult * atr)
    current_tp := i_useTP ? close - (i_tpMult * atr) : na
    sl_phase := 0
    trail_extreme := na
    add_count := 0
    phase1_done := false
    phase2_done := false
    tradeGrade := "B"

else if c_long_base and not inPosition and lastTradeDir == "LONG"
    inPosition := true
    posDir := "LONG"
    entryPrice := close
    entryBar := bar_index
    current_sl := close - (i_slMult * atr)
    current_tp := i_useTP ? close + (i_tpMult * atr) : na
    sl_phase := 0
    trail_extreme := na
    add_count := 0
    phase1_done := false
    phase2_done := false
    tradeGrade := "C"

else if c_short_base and not inPosition and lastTradeDir == "SHORT"
    inPosition := true
    posDir := "SHORT"
    entryPrice := close
    entryBar := bar_index
    current_sl := close + (i_slMult * atr)
    current_tp := i_useTP ? close - (i_tpMult * atr) : na
    sl_phase := 0
    trail_extreme := na
    add_count := 0
    phase1_done := false
    phase2_done := false
    tradeGrade := "C"

else if inPosition and posDir == "LONG" and add_long_trigger
    add_count := add_count + 1
    didAdd := true
    if sl_phase < 3
        sl_phase := 3
        current_tp := na
        phaseChanged := true

else if inPosition and posDir == "SHORT" and add_short_trigger
    add_count := add_count + 1
    didAdd := true
    if sl_phase < 3
        sl_phase := 3
        current_tp := na
        phaseChanged := true

// ═══════════════════════════════════════════════════════════════════════════
// TRAIL EXTREME + PHASE TRANSITIONS
// ═══════════════════════════════════════════════════════════════════════════

if inPosition
    if posDir == "LONG"
        trail_extreme := na(trail_extreme) ? high : math.max(trail_extreme, high)
    else
        trail_extreme := na(trail_extreme) ? low : math.min(trail_extreme, low)

if inPosition and bar_index > entryBar
    if not phase1_done
        if posDir == "LONG" and cloud2_cross_bull
            phase1_done := true
            sl_phase := 1
            float new_sl = low - atr
            if new_sl > current_sl
                current_sl := new_sl
            current_tp := current_tp + atr
            phaseChanged := true
        else if posDir == "SHORT" and cloud2_cross_bear
            phase1_done := true
            sl_phase := 1
            float new_sl = high + atr
            if new_sl < current_sl
                current_sl := new_sl
            current_tp := current_tp - atr
            phaseChanged := true

    else if phase1_done and not phase2_done
        if posDir == "LONG" and cloud3_cross_bull
            phase2_done := true
            sl_phase := 2
            current_sl := current_sl + atr
            current_tp := current_tp + atr
            phaseChanged := true
        else if posDir == "SHORT" and cloud3_cross_bear
            phase2_done := true
            sl_phase := 2
            current_sl := current_sl - atr
            current_tp := current_tp - atr
            phaseChanged := true

    if phase2_done and sl_phase == 2
        bool sync_bull = posDir == "LONG" and cloud3_bull and cloud4_bull
        bool sync_bear = posDir == "SHORT" and not cloud3_bull and not cloud4_bull
        if sync_bull or sync_bear
            sl_phase := 3
            current_tp := na
            phaseChanged := true

    if sl_phase == 3
        if posDir == "LONG"
            float new_sl = i_useAngleTrail and angleSteepLong ? cloud_top + atr : cloud_bottom - atr
            if new_sl > current_sl
                current_sl := new_sl
        else
            float new_sl = i_useAngleTrail and angleSteepShort ? cloud_bottom - atr : cloud_top + atr
            if new_sl < current_sl
                current_sl := new_sl

// ═══════════════════════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ═══════════════════════════════════════════════════════════════════════════

bool didEnterLong = inPosition and posDir == "LONG" and (not inPosition[1] or posDir[1] != "LONG")
bool didEnterShort = inPosition and posDir == "SHORT" and (not inPosition[1] or posDir[1] != "SHORT")

// Entry orders
if didEnterLong
    strategy.entry("Long", strategy.long)
if didEnterShort
    strategy.entry("Short", strategy.short)

// ADD pyramid orders
if didAdd
    if posDir == "LONG"
        strategy.entry("Long", strategy.long)
    else
        strategy.entry("Short", strategy.short)

// Exit orders
bool anyExit = exitCloud2 or exitSL or exitTP
if anyExit
    strategy.close_all(exitCloud2 ? "C2 Exit" : exitSL ? "SL Hit" : "TP Hit")

// ═══════════════════════════════════════════════════════════════════════════
// VISUALS (SL/TP lines + cloud fills)
// ═══════════════════════════════════════════════════════════════════════════

color slColor = sl_phase == 0 ? color.red : sl_phase == 1 ? #ff6666 : sl_phase == 2 ? color.orange : color.yellow
plot(inPosition ? current_sl : na, "Stop Loss", slColor, 2, plot.style_linebr)

color tpColor = sl_phase == 0 ? color.green : sl_phase == 1 ? #66ff66 : color.lime
plot(inPosition and not na(current_tp) ? current_tp : na, "Take Profit", tpColor, 1, plot.style_linebr)

pC2a = plot(i_showCloud2 ? ema5 : na, "EMA 5", color.new(color.teal, 70))
pC2b = plot(i_showCloud2 ? ema12 : na, "EMA 12", color.new(color.teal, 70))
fill(pC2a, pC2b, cloud2_bull ? color.new(color.teal, 85) : color.new(color.maroon, 85))

pC3a = plot(i_showCloud3 ? ema34 : na, "EMA 34", color.new(color.blue, 70))
pC3b = plot(i_showCloud3 ? ema50 : na, "EMA 50", color.new(color.blue, 70))
fill(pC3a, pC3b, cloud3_bull ? color.new(color.green, 85) : color.new(color.red, 85))

pC4a = plot(i_showCloud4 ? ema72 : na, "EMA 72", color.new(color.purple, 70))
pC4b = plot(i_showCloud4 ? ema89 : na, "EMA 89", color.new(color.purple, 70))
fill(pC4a, pC4b, cloud4_bull ? color.new(color.green, 90) : color.new(color.red, 90))

// ═══════════════════════════════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════

if i_showDash and barstate.islast
    var table dash = table.new(position.top_right, 2, 11, bgcolor=color.new(#1e222d, 10))

    table.cell(dash, 0, 0, "4P v3.4.1S", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, posDir, text_color=posDir == "LONG" ? color.lime : posDir == "SHORT" ? color.red : color.gray, text_size=size.small)

    table.cell(dash, 0, 1, "9-3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 1, str.tostring(stoch_9_3, "#.0"), text_color=stoch_9_3 < crossLow ? color.lime : stoch_9_3 > crossHigh ? color.red : color.white, text_size=size.tiny)

    table.cell(dash, 0, 2, "14-3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 2, str.tostring(stoch_14_3, "#.0"), text_color=stoch_14_3 < zoneLow ? color.lime : stoch_14_3 > zoneHigh ? color.red : color.white, text_size=size.tiny)

    table.cell(dash, 0, 3, "40-3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(stoch_40_3, "#.0"), text_color=stoch_40_3 < zoneLow ? color.lime : stoch_40_3 > zoneHigh ? color.red : color.white, text_size=size.tiny)

    table.cell(dash, 0, 4, "60-10", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 4, str.tostring(stoch_60_10, "#.0"), text_color=stoch_60_10 < zoneLow ? color.lime : stoch_60_10 > zoneHigh ? color.red : color.white, text_size=size.tiny)

    string phaseStr = inPosition ? "P" + str.tostring(sl_phase) : "---"
    color phaseColor = sl_phase == 0 ? color.white : sl_phase == 1 ? #ff6666 : sl_phase == 2 ? color.orange : color.yellow
    table.cell(dash, 0, 5, "Phase", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 5, phaseStr, text_color=inPosition ? phaseColor : color.gray, text_size=size.tiny)

    string entryStr = inPosition ? str.tostring(1 + add_count) + tradeGrade : "---"
    table.cell(dash, 0, 6, "Entries", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 6, entryStr, text_color=inPosition ? color.white : color.gray, text_size=size.tiny)

    table.cell(dash, 0, 7, "Cloud3", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 7, cloud3_bull ? "BULL" : "BEAR", text_color=cloud3_bull ? color.lime : color.red, text_size=size.tiny)

    color c2Color = inPosition ? (posDir == "LONG" ? (cloud2_bull ? color.lime : color.fuchsia) : (not cloud2_bull ? color.lime : color.fuchsia)) : (cloud2_bull ? color.lime : color.red)
    table.cell(dash, 0, 8, "Cloud2", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 8, cloud2_bull ? "BULL" : "BEAR", text_color=c2Color, text_size=size.tiny)

    table.cell(dash, 0, 9, "SL", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 9, inPosition ? str.tostring(current_sl, "#.##") : "---", text_color=inPosition ? slColor : color.gray, text_size=size.tiny)

    table.cell(dash, 0, 10, "TP", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 10, inPosition and not na(current_tp) ? str.tostring(current_tp, "#.##") : "---", text_color=inPosition ? tpColor : color.gray, text_size=size.tiny)
