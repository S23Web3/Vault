# Auto-detect text files and normalize line endings
* text=auto

# Force LF for scripts (bash chokes on CRLF)
*.sh text eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Force CRLF for Windows-only scripts
*.ps1 text eol=crlf

# Binary files -- don't touch
*.png binary
*.jpg binary
*.pdf binary
*.pkl binary
*.parquet binary